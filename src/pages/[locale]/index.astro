---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvolutionTimelineSection from "../../components/sections/home/EvolutionTimelineSection.astro";
import HomeHero from "../../components/sections/home/HomeHero.astro";
import HomeRevealScript from "../../components/sections/home/HomeRevealScript.astro";
import ManufacturingScaleSection from "../../components/sections/home/ManufacturingScaleSection.astro";
import MarketDirectionSection from "../../components/sections/home/MarketDirectionSection.astro";
import MobilityPlatformsSection from "../../components/sections/home/MobilityPlatformsSection.astro";
import NationalOEMSection from "../../components/sections/home/NationalOEMSection.astro";
import { locales } from "../../i18n";
import type { Locale } from "../../i18n";
import en from "../../i18n/locales/en";
import ky from "../../i18n/locales/ky";
import ru from "../../i18n/locales/ru";
import zh from "../../i18n/locales/zh";

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== "en")
    .map((locale) => ({
      params: { locale },
    }));
}

const translations = {
  en,
  ru,
  zh,
  ky,
} satisfies Record<Locale, typeof en>;

const locale = Astro.params.locale as Locale;
const home = translations[locale].home;

const description =
  "BELES develops engineering-led mobility solutions for industrial and commercial transportation.";
---

<BaseLayout title="BELES" description={description} lang={locale}>
  <main id="main">
    <HomeHero />
    <NationalOEMSection content={home.nationalOem} />
    <EvolutionTimelineSection content={home.evolution} />
    <MobilityPlatformsSection content={home.platforms} />
    <ManufacturingScaleSection content={home.manufacturing} />
    <MarketDirectionSection content={home.market} />
  </main>
  <HomeRevealScript />
</BaseLayout>
