---
import InternalPageHero from "../../components/sections/internal/InternalPageHero.astro";
import ProjectsPage from "../../components/sections/projects/ProjectsPage.astro";
import { locales } from "../../i18n";
import type { Locale } from "../../i18n";
import en from "../../i18n/locales/en";
import ky from "../../i18n/locales/ky";
import ru from "../../i18n/locales/ru";
import zh from "../../i18n/locales/zh";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { internalPageKeys } from "../../lib/internalPages";
import type { InternalPageKey } from "../../lib/internalPages";

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== "en")
    .flatMap((locale) =>
      internalPageKeys.map((page) => ({
        params: { locale, page },
      })),
    );
}

const translations = { en, ru, zh, ky } satisfies Record<Locale, typeof en>;
const locale = Astro.params.locale as Locale;
const page = Astro.params.page as InternalPageKey;
const content = translations[locale].internalPages[page];
---

<BaseLayout title={content.metadataTitle} description={content.description} lang={locale}>
  <main id="main">
    {
      page === "projects" ? (
        <ProjectsPage content={content} />
      ) : (
        <InternalPageHero
          eyebrow={content.eyebrow}
          title={content.title}
          description={content.description}
        />
      )
    }
  </main>
</BaseLayout>
