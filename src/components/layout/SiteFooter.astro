---
import en from "../../i18n/locales/en";
import ky from "../../i18n/locales/ky";
import ru from "../../i18n/locales/ru";
import zh from "../../i18n/locales/zh";
import type { Locale } from "../../i18n";
import {
  getLocaleFromPathname,
  getLocalizedPath,
  getPathWithoutLocalePrefix,
  localeItems,
  navItems,
} from "../../lib/navigation";

const translations = { en, ru, zh, ky } satisfies Record<Locale, typeof en>;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const currentPath = getPathWithoutLocalePrefix(Astro.url.pathname);
const footer = translations[currentLocale].footer;

const localizedNavItems = navItems.map((item) => ({
  ...item,
  label: footer.nav[item.key],
  href: getLocalizedPath(item.href, currentLocale),
  isCurrent: currentPath === item.href,
}));

const footerLocaleOrder: Locale[] = ["en", "ru", "ky", "zh"];
const footerLocaleItems = footerLocaleOrder.map((locale) =>
  localeItems.find((item) => item.locale === locale)!,
);
---

<footer class="site-footer" aria-labelledby="footer-title">
  <div class="footer-shell">
    <div class="footer-top">
      <a
        class="footer-wordmark"
        href={getLocalizedPath("/", currentLocale)}
        aria-label="BELES home"
      >
        <img src="/img/branding/beles-logo-header-white.svg" alt="" width="529" height="96" />
      </a>
      <p id="footer-title" class="footer-positioning">{footer.positioning}</p>
    </div>

    <div class="footer-middle">
      <nav class="footer-column footer-navigation" aria-label={footer.navigationLabel}>
        <p class="footer-label">{footer.navigationLabel}</p>
        <div class="footer-nav-links">
          {
            localizedNavItems.map((item) => (
              <a href={item.href} aria-current={item.isCurrent ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>

      <div class="footer-column footer-contacts">
        <p class="footer-label">{footer.contactsLabel}</p>
        <a href="tel:+996312906090">
          <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span>+996 312 90 60 90</span>
        </a>
        <a href="mailto:info@beles.group">
          <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="1"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
          <span>info@beles.group</span>
        </a>
      </div>

      <div class="footer-column footer-social">
        <p class="footer-label">{footer.socialLabel}</p>
        <!-- TODO: Replace with the confirmed official BELES Instagram URL. -->
        <a href="#">
          <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle class="footer-icon-dot" cx="17.5" cy="6.5" r="0.75"></circle>
          </svg>
          <span>Instagram</span>
        </a>
      </div>

      <nav class="footer-column footer-languages" aria-label={footer.languageLabel}>
        <p class="footer-label">{footer.languageLabel}</p>
        <div class="footer-language-links">
          {
            footerLocaleItems.map((item) => (
              <a
                href={getLocalizedPath(currentPath, item.locale)}
                lang={item.locale}
                aria-current={item.locale === currentLocale ? "true" : undefined}
              >
                {item.shortLabel}
              </a>
            ))
          }
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>{footer.copyright}</p>
      <p>{footer.platformLabel}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    border-top: 1px solid rgba(66, 109, 255, 0.22);
    background:
      linear-gradient(90deg, rgba(41, 70, 143, 0.07), transparent 26%),
      linear-gradient(180deg, rgba(16, 22, 32, 0.34), rgba(7, 10, 16, 0) 48%), #070a10;
    color: var(--color-text-primary);
  }

  .footer-shell {
    width: min(100%, var(--container-max));
    margin-inline: auto;
    padding: clamp(2.25rem, 3.2vw, 3rem) var(--container-gutter) clamp(1.25rem, 2vw, 1.75rem);
  }

  .footer-top {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.72fr);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
    padding-bottom: clamp(1.5rem, 2.2vw, 2rem);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .footer-top::after {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 4rem;
    height: 1px;
    background: var(--color-brand-blue-bright);
    content: "";
  }

  .footer-wordmark {
    display: block;
    width: clamp(17rem, 27vw, 24rem);
    max-width: 100%;
    text-decoration: none;
  }

  .footer-wordmark img {
    width: 100%;
    height: auto;
  }

  .footer-positioning {
    position: relative;
    max-width: 34rem;
    padding-left: 1.5rem;
    margin: 0;
    color: var(--color-paper-muted);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.45;
  }

  .footer-positioning::before {
    position: absolute;
    top: 0.15rem;
    bottom: 0.15rem;
    left: 0;
    width: 2px;
    background: var(--color-brand-blue-bright);
    content: "";
  }

  .footer-middle {
    display: grid;
    grid-template-columns: 1.2fr 1.25fr 0.9fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding-block: clamp(1.5rem, 2.5vw, 2rem);
  }

  .footer-column {
    min-width: 0;
  }

  .footer-label,
  .footer-bottom p {
    margin: 0;
  }

  .footer-label {
    margin-bottom: 0.875rem;
    color: var(--color-brand-blue-bright);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-transform: uppercase;
  }

  .footer-nav-links,
  .footer-contacts,
  .footer-social {
    display: grid;
    align-content: start;
    gap: 0.5rem;
  }

  .footer-nav-links a,
  .footer-contacts a,
  .footer-social a,
  .footer-language-links a {
    width: fit-content;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.35;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-contacts a,
  .footer-social a {
    display: inline-flex;
    gap: 0.625rem;
    align-items: center;
  }

  .footer-icon {
    width: 1rem;
    height: 1rem;
    flex: 0 0 1rem;
    fill: none;
    stroke: var(--color-brand-steel);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
    transition: stroke var(--duration-fast) var(--ease-out);
  }

  .footer-icon-dot {
    fill: var(--color-brand-steel);
    stroke: none;
    transition: fill var(--duration-fast) var(--ease-out);
  }

  .footer-contacts a:hover .footer-icon,
  .footer-contacts a:focus-visible .footer-icon,
  .footer-social a:hover .footer-icon,
  .footer-social a:focus-visible .footer-icon {
    stroke: var(--color-brand-blue-bright);
  }

  .footer-social a:hover .footer-icon-dot,
  .footer-social a:focus-visible .footer-icon-dot {
    fill: var(--color-brand-blue-bright);
  }

  .footer-nav-links a:hover,
  .footer-nav-links a:focus-visible,
  .footer-nav-links a[aria-current="page"],
  .footer-contacts a:hover,
  .footer-contacts a:focus-visible,
  .footer-social a:hover,
  .footer-social a:focus-visible,
  .footer-language-links a:hover,
  .footer-language-links a:focus-visible,
  .footer-language-links a[aria-current="true"] {
    color: var(--color-text-primary);
  }

  .footer-language-links {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    align-items: center;
  }

  .footer-language-links a {
    position: relative;
    padding-inline: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .footer-language-links a:first-child {
    padding-left: 0;
  }

  .footer-language-links a + a::before {
    position: absolute;
    top: 50%;
    left: 0;
    width: 1px;
    height: 1rem;
    background: var(--color-border-strong);
    content: "";
    transform: translateY(-50%);
  }

  .footer-language-links a[aria-current="true"]::after {
    position: absolute;
    right: 0.875rem;
    bottom: -0.5rem;
    left: 0.875rem;
    height: 2px;
    background: var(--color-brand-blue-bright);
    content: "";
  }

  .footer-language-links a:first-child[aria-current="true"]::after {
    left: 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1.125rem;
    border-top: 1px solid var(--color-border-subtle);
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    line-height: 1.4;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .footer-middle {
      grid-template-columns: 1fr 1fr;
      row-gap: 1.75rem;
    }
  }

  @media (max-width: 560px) {
    .footer-shell {
      padding-top: 2rem;
    }

    .footer-wordmark {
      width: min(100%, 20rem);
    }

    .footer-positioning {
      max-width: 21rem;
      padding-left: 1rem;
      font-size: 0.9375rem;
    }

    .footer-middle {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding-block: 1.5rem;
    }

    .footer-nav-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.5rem;
    }

    .footer-label {
      margin-bottom: 0.875rem;
    }

    .footer-bottom {
      display: grid;
      gap: 0.625rem;
      padding-top: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-nav-links a,
    .footer-contacts a,
    .footer-social a,
    .footer-language-links a {
      transition-duration: 1ms;
    }
  }
</style>
