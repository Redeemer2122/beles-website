---
import {
  getLocaleFromPathname,
  getLocalizedPath,
  getPathWithoutLocalePrefix,
  localeItems,
  navItems,
} from "../../lib/navigation";

const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const currentPath = getPathWithoutLocalePrefix(Astro.url.pathname);
const currentYear = new Date().getFullYear();

const localizedNavItems = navItems.map((item) => ({
  ...item,
  href: getLocalizedPath(item.href, currentLocale),
  isCurrent: currentPath === item.href,
}));

const contactHref = getLocalizedPath("/contact/", currentLocale);
const inquiryItems = ["Partnerships", "Commercial inquiries", "Engineering programs"];
---

<footer class="site-footer" aria-labelledby="footer-title">
  <div class="footer-shell">
    <div class="footer-brand">
      <a
        class="footer-wordmark"
        href={getLocalizedPath("/", currentLocale)}
        aria-label="BELES home"
      >
        BELES
      </a>
      <p id="footer-title">Engineering mobility for a new industrial era.</p>
      <a class="footer-cta" href={contactHref}>Start a conversation</a>
    </div>

    <div class="footer-grid">
      <nav class="footer-nav" aria-label="Footer navigation">
        <p>Explore</p>
        {
          localizedNavItems.map((item) => (
            <a href={item.href} aria-current={item.isCurrent ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="footer-inquiries" aria-label="Inquiry categories">
        <p>Inquiries</p>
        <ul>
          {inquiryItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <nav class="footer-locales" aria-label="Footer language navigation">
        <p>Language</p>
        {
          localeItems.map((item) => (
            <a
              href={getLocalizedPath(currentPath, item.locale)}
              aria-current={item.locale === currentLocale ? "true" : undefined}
            >
              <span>{item.shortLabel}</span>
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© {currentYear} BELES. All rights reserved.</p>
      <p>Industrial mobility platform</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: clamp(4rem, 10vw, 8rem) var(--container-gutter) clamp(1.5rem, 4vw, 3rem);
    background:
      radial-gradient(circle at 18% 0%, rgba(41, 70, 143, 0.22), transparent 32rem),
      linear-gradient(180deg, rgba(8, 11, 16, 0), var(--color-bg-secondary) 18%),
      var(--color-bg-primary);
    color: var(--color-text-primary);
  }

  .footer-shell {
    width: min(100%, var(--container-max));
    margin-inline: auto;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(145deg, rgba(16, 22, 32, 0.82), rgba(3, 4, 6, 0.94)),
      var(--color-bg-secondary);
    box-shadow:
      inset 0 1px 0 rgba(247, 248, 250, 0.08),
      0 2rem 5rem rgba(3, 4, 6, 0.34);
  }

  .footer-brand {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: end;
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .footer-wordmark {
    display: inline-flex;
    width: fit-content;
    background: linear-gradient(
      110deg,
      var(--color-text-primary) 0%,
      var(--color-brand-silver) 34%,
      var(--color-brand-steel) 58%,
      var(--color-paper) 100%
    );
    background-clip: text;
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 13vw, 11rem);
    font-weight: 950;
    letter-spacing: 0.16em;
    line-height: 0.88;
    text-decoration: none;
    text-transform: uppercase;
    -webkit-text-fill-color: transparent;
  }

  .footer-brand p {
    max-width: 38rem;
    margin: 1.25rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1.125rem, 2vw, 1.75rem);
    letter-spacing: -0.01em;
    line-height: var(--leading-tight);
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding-inline: 1.125rem;
    border: 1px solid rgba(66, 109, 255, 0.5);
    border-radius: var(--radius-full);
    background:
      linear-gradient(180deg, rgba(66, 109, 255, 0.2), rgba(23, 44, 102, 0.3)),
      var(--color-brand-blue);
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .footer-nav,
  .footer-inquiries,
  .footer-locales {
    display: grid;
    align-content: start;
    gap: 0.75rem;
  }

  .footer-nav p,
  .footer-inquiries p,
  .footer-locales p,
  .footer-bottom p {
    margin: 0;
  }

  .footer-nav p,
  .footer-inquiries p,
  .footer-locales p {
    margin-bottom: 0.35rem;
    color: var(--color-brand-steel);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-transform: uppercase;
  }

  .footer-nav a,
  .footer-locales a {
    width: fit-content;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.25;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .footer-locales a {
    display: inline-flex;
    gap: 0.75rem;
    align-items: baseline;
  }

  .footer-locales span {
    color: var(--color-brand-steel);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: var(--tracking-label);
  }

  .footer-inquiries ul {
    display: grid;
    gap: 0.75rem;
    padding: 0;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.25;
    list-style: none;
  }

  .footer-inquiries li {
    position: relative;
    padding-left: 1rem;
  }

  .footer-inquiries li::before {
    position: absolute;
    top: 0.5em;
    left: 0;
    width: 0.375rem;
    height: 0.375rem;
    border: 1px solid var(--color-brand-blue-bright);
    border-radius: var(--radius-full);
    content: "";
  }

  .footer-wordmark:focus-visible,
  .footer-cta:focus-visible,
  .footer-nav a:focus-visible,
  .footer-locales a:focus-visible {
    outline: 2px solid var(--color-brand-blue-bright);
    outline-offset: 4px;
  }

  .footer-cta:hover,
  .footer-cta:focus-visible {
    border-color: var(--color-brand-blue-bright);
    background:
      linear-gradient(180deg, rgba(66, 109, 255, 0.3), rgba(23, 44, 102, 0.4)),
      var(--color-brand-blue);
    transform: translateY(-1px);
  }

  .footer-nav a:hover,
  .footer-nav a:focus-visible,
  .footer-nav a[aria-current="page"],
  .footer-locales a:hover,
  .footer-locales a:focus-visible,
  .footer-locales a[aria-current="true"] {
    color: var(--color-text-primary);
    transform: translateX(0.125rem);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border-subtle);
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    line-height: 1.4;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .footer-brand {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .footer-cta {
      width: fit-content;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding-top: 3rem;
    }

    .footer-shell {
      padding: 1rem;
      border-radius: var(--radius-lg);
    }

    .footer-wordmark {
      letter-spacing: 0.1em;
    }

    .footer-grid,
    .footer-bottom {
      grid-template-columns: 1fr;
    }

    .footer-grid {
      display: grid;
      gap: 2rem;
    }

    .footer-bottom {
      display: grid;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-cta,
    .footer-nav a,
    .footer-locales a {
      transition-duration: 1ms;
    }
  }
</style>
