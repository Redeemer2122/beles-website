---
import {
  getLocaleFromPathname,
  getLocalizedPath,
  getPathWithoutLocalePrefix,
  localeItems,
} from "../../lib/navigation";

const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const currentPath = getPathWithoutLocalePrefix(Astro.url.pathname);
const currentLocaleItem =
  localeItems.find((item) => item.locale === currentLocale) ?? localeItems[0];
---

<details class="language-switcher">
  <summary aria-label={`Current language: ${currentLocaleItem.label}. Change language.`}>
    <span>{currentLocaleItem.shortLabel}</span>
  </summary>
  <div class="language-menu" aria-label="Language selector">
    {
      localeItems.map((item) => (
        <a
          href={getLocalizedPath(currentPath, item.locale)}
          aria-label={`Switch language to ${item.label}`}
          aria-current={item.locale === currentLocale ? "true" : undefined}
        >
          <span>{item.shortLabel}</span>
        </a>
      ))
    }
  </div>
</details>

<style>
  .language-switcher {
    position: relative;
    color: var(--color-text-primary);
  }

  summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 1.8rem;
    padding: 0 0.05rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(17, 23, 34, 0.74);
    cursor: pointer;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.035em;
    line-height: 1;
    text-transform: uppercase;
    transition:
      color var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::marker {
    content: "";
  }

  summary::after {
    width: 0.35rem;
    height: 0.35rem;
    margin-left: 0.38rem;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    content: "";
    transform: translateY(-0.125rem) rotate(45deg);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .language-switcher[open] summary::after {
    transform: translateY(0.125rem) rotate(225deg);
  }

  summary:hover,
  .language-switcher[open] summary {
    color: #0c43df;
    opacity: 1;
  }

  summary:focus-visible {
    outline: 2px solid var(--color-brand-blue-bright);
    outline-offset: 4px;
  }

  .language-menu {
    position: absolute;
    top: calc(100% + 0.625rem);
    right: 0;
    z-index: var(--z-overlay);
    display: grid;
    min-width: 5.1rem;
    padding: 0.24rem;
    border: 1px solid rgba(45, 58, 79, 0.12);
    border-radius: 0.18rem;
    background: rgba(248, 250, 252, 0.96);
    box-shadow: 0 0.7rem 1.6rem rgba(37, 43, 50, 0.12);
  }

  .language-menu a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.65rem;
    border-radius: 0.08rem;
    color: rgba(17, 23, 34, 0.72);
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .language-menu a span:first-child {
    color: currentColor;
  }

  .language-menu a:hover,
  .language-menu a:focus-visible,
  .language-menu a[aria-current="true"] {
    background: rgba(12, 67, 223, 0.08);
    color: #111722;
  }

  .language-menu a:focus-visible {
    outline: 2px solid var(--color-brand-blue-bright);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .language-switcher {
      width: 100%;
    }

    summary {
      width: 100%;
      justify-content: space-between;
      min-height: 3rem;
      padding-inline: 1rem;
    }

    .language-menu {
      position: static;
      margin-top: 0.5rem;
      box-shadow: none;
    }
  }
</style>
