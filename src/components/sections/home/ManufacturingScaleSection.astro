---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type Props = {
  content: {
    title: string;
    body: string;
    cta: string;
    primaryMetric: {
      value: string;
      label: string;
    };
    secondaryMetric: {
      value: string;
      label: string;
    };
    process: string[];
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/capabilities/", currentLocale);
---

<section class="manufacturing-section" aria-labelledby="manufacturing-title">
  <div class="manufacturing-shell">
    <div class="scale-block">
      <strong data-reveal>{content.primaryMetric.value}</strong>
      <span data-reveal style="--reveal-delay: 80ms">{content.primaryMetric.label}</span>
    </div>

    <div class="manufacturing-copy">
      <h2 id="manufacturing-title" data-reveal>{content.title}</h2>
      <p data-reveal style="--reveal-delay: 90ms">{content.body}</p>
      <div class="secondary-metric" data-reveal style="--reveal-delay: 150ms">
        <strong>{content.secondaryMetric.value}</strong>
        <span>{content.secondaryMetric.label}</span>
      </div>
      <a class="home-text-link" href={ctaHref} data-reveal style="--reveal-delay: 210ms">
        <span>{content.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="process-flow" aria-label="BELES production flow">
      <span class="process-axis" aria-hidden="true"></span>
      {
        content.process.map((step, index) => (
          <article data-reveal style={`--reveal-delay: ${index * 60}ms`}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{step}</strong>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .manufacturing-section {
    overflow: clip;
    background: linear-gradient(180deg, #111722 0%, #171d27 100%), var(--color-bg-secondary);
    color: #f7f8fa;
  }

  .manufacturing-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.78fr);
    gap: clamp(2rem, 5vw, 5rem);
    width: min(100% - (var(--container-gutter) * 2), var(--container-max));
    margin-inline: auto;
    padding-block: clamp(6rem, 12vw, 13rem);
  }

  .scale-block {
    position: relative;
    min-height: clamp(24rem, 42vw, 39rem);
    border-top: 1px solid rgba(247, 248, 250, 0.18);
    background:
      linear-gradient(
        145deg,
        rgba(66, 109, 255, 0.18),
        rgba(255, 255, 255, 0.03) 45%,
        rgba(255, 255, 255, 0.09)
      ),
      repeating-linear-gradient(90deg, rgba(247, 248, 250, 0.07) 0 1px, transparent 1px 5rem);
  }

  .scale-block::after {
    position: absolute;
    right: 8%;
    bottom: 12%;
    width: 44%;
    height: 42%;
    border-right: 1px solid rgba(66, 109, 255, 0.46);
    border-bottom: 1px solid rgba(66, 109, 255, 0.46);
    content: "";
  }

  .scale-block strong {
    display: block;
    padding: clamp(1.4rem, 3vw, 2.5rem);
    color: #fff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(4.3rem, 12vw, 12.5rem);
    font-weight: 520;
    letter-spacing: -0.075em;
    line-height: 0.82;
  }

  .scale-block span {
    position: absolute;
    right: clamp(1.4rem, 3vw, 2.5rem);
    bottom: clamp(1.4rem, 3vw, 2.5rem);
    max-width: 19rem;
    color: rgba(247, 248, 250, 0.72);
    font-size: clamp(1rem, 1.3vw, 1.22rem);
    font-weight: 560;
    line-height: 1.45;
  }

  .manufacturing-copy {
    align-self: center;
  }

  .manufacturing-copy h2 {
    max-width: 12ch;
    margin: 0;
    color: #fff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.8rem, 5.8vw, 6rem);
    font-weight: 500;
    letter-spacing: -0.052em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .manufacturing-copy p {
    max-width: 36rem;
    margin: 1.55rem 0 0;
    color: rgba(247, 248, 250, 0.7);
    font-size: clamp(1rem, 1.12vw, 1.12rem);
    font-weight: 500;
    line-height: 1.62;
  }

  .secondary-metric {
    display: grid;
    gap: 0.45rem;
    max-width: 22rem;
    margin-top: 2rem;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(247, 248, 250, 0.18);
  }

  .secondary-metric strong {
    color: #8fa6ff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2rem, 3vw, 3.25rem);
    font-weight: 560;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .secondary-metric span {
    color: rgba(247, 248, 250, 0.64);
    font-size: 0.9rem;
    font-weight: 540;
    line-height: 1.4;
  }

  .home-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    margin-top: 2rem;
    color: #9fb2ff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.045em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .home-text-link span:last-child {
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.2rem);
  }

  .process-flow {
    position: relative;
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .process-axis {
    position: absolute;
    top: 1.05rem;
    right: 0;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(143, 166, 255, 0.8), rgba(247, 248, 250, 0.16));
  }

  .process-flow article {
    position: relative;
    display: grid;
    gap: 1.3rem;
    padding-top: 2.55rem;
  }

  .process-flow article::before {
    position: absolute;
    top: 0.73rem;
    left: 0;
    width: 0.64rem;
    height: 0.64rem;
    border: 1px solid rgba(143, 166, 255, 0.8);
    background: #171d27;
    content: "";
    transform: rotate(45deg);
  }

  .process-flow span {
    color: rgba(247, 248, 250, 0.38);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .process-flow strong {
    color: rgba(247, 248, 250, 0.82);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.88rem, 1vw, 1rem);
    font-weight: 600;
    line-height: 1.18;
  }

  @media (max-width: 1000px) {
    .manufacturing-shell {
      grid-template-columns: 1fr;
    }

    .scale-block {
      min-height: 24rem;
    }

    .process-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.35rem 1rem;
    }

    .process-axis {
      display: none;
    }

    .process-flow article {
      border-top: 1px solid rgba(247, 248, 250, 0.14);
    }

    .process-flow article::before {
      content: none;
    }
  }

  @media (max-width: 560px) {
    .manufacturing-copy h2 {
      font-size: clamp(2.55rem, 12vw, 4rem);
    }

    .scale-block strong {
      font-size: clamp(3.65rem, 18vw, 5.4rem);
    }

    .scale-block span {
      right: 1.3rem;
      left: 1.3rem;
    }

    .process-flow {
      grid-template-columns: 1fr;
    }
  }
</style>
