---
import phosphorIcons from "@iconify-json/ph/icons.json";

type Metric = { value: string; label: string; text: string };

type Props = {
  content: {
    eyebrow: string;
    label: string;
    title: string;
    body: string;
    metrics: { territory: Metric; workshops: Metric };
    processLabel: string;
    process: string[];
    imageAlt: string;
  };
};

const { content } = Astro.props;
const processIconNames = ["bus", "robot", "car-profile", "factory", "truck"] as const;
const processIcons = processIconNames.map((name) => phosphorIcons.icons[name]);
---

<section class="manufacturing" aria-labelledby="manufacturing-title">
  <div class="image-layer" aria-hidden="true">
    <img
      src="/img/manufacturing/manufacturing-floor.webp"
      alt=""
      width="2048"
      height="1152"
      loading="lazy"
    />
  </div>
  <div class="blueprint" aria-hidden="true"></div>

  <div class="shell">
    <header class="chapter" data-reveal>
      <p>{content.eyebrow}</p><span></span><p>{content.label}</p>
    </header>

    <div class="main-copy">
      <h2 id="manufacturing-title" data-reveal style="--reveal-delay: 60ms">{content.title}</h2>
      <p class="intro" data-reveal style="--reveal-delay: 120ms">{content.body}</p>
      <div class="metrics">
        {
          [content.metrics.territory, content.metrics.workshops].map((metric, index) => (
            <article data-reveal style={`--reveal-delay: ${180 + index * 70}ms`}>
              <>
                <strong>{metric.value}</strong>
                <h3>{metric.label}</h3>
                <p>{metric.text}</p>
              </>
            </article>
          ))
        }
      </div>
    </div>

    <figure class="mobile-image" data-reveal>
      <img
        src="/img/manufacturing/manufacturing-floor.webp"
        alt={content.imageAlt}
        width="2048"
        height="1152"
        loading="lazy"
      />
    </figure>

    <div class="process" data-reveal style="--reveal-delay: 260ms">
      <ol aria-label={content.processLabel}>
        {
          content.process.map((step, index) => (
            <li>
              <span class="number">{String(index + 1).padStart(2, "0")}</span>
              <div class="step-content">
                <svg viewBox="0 0 256 256" aria-hidden="true" set:html={processIcons[index].body} />
                <strong>{step}</strong>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .manufacturing {
    position: relative;
    isolation: isolate;
    overflow: clip;
    min-height: clamp(52rem, 58vw, 64rem);
    color: #f5f7fb;
    background: linear-gradient(180deg, #0b111b, #070b12);
  }
  .manufacturing::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(25, 45, 76, 0.22), transparent 18rem),
      radial-gradient(circle at 18% 45%, rgba(18, 83, 255, 0.09), transparent 25rem);
    content: "";
  }
  .image-layer {
    position: absolute;
    inset: 0 0 0 34%;
    z-index: -2;
  }
  .image-layer::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        #0a1019 0%,
        rgba(8, 13, 21, 0.96) 14%,
        rgba(8, 13, 21, 0.78) 29%,
        rgba(8, 13, 21, 0.42) 48%,
        rgba(8, 13, 21, 0.12) 68%,
        transparent 82%
      ),
      linear-gradient(180deg, rgba(5, 9, 15, 0.58), transparent 24%, transparent 64%, #070b12 100%);
    content: "";
  }
  .image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    filter: saturate(0.75) contrast(1.08) brightness(0.78);
  }
  .blueprint {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.28;
    background-image:
      linear-gradient(rgba(126, 159, 210, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(126, 159, 210, 0.07) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(90deg, #000, transparent 55%);
  }
  .shell {
    box-sizing: border-box;
    width: 100%;
    margin: auto;
    padding: clamp(6.5rem, 7.5vw, 9rem) clamp(2rem, 4.4vw, 5.5rem) clamp(5rem, 6.25vw, 7.5rem);
  }
  .chapter {
    display: grid;
    grid-template-columns: auto minmax(3rem, 1fr) auto;
    align-items: center;
    gap: 1.4rem;
  }
  .chapter p {
    margin: 0;
    color: #407bff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.7rem, 0.68vw, 0.82rem);
    font-weight: 750;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .chapter p:last-child {
    color: rgba(239, 244, 252, 0.54);
  }
  .chapter > span {
    height: 1px;
    background: linear-gradient(90deg, #2868ff 0 3.5rem, rgba(220, 231, 248, 0.18) 3.5rem);
  }
  .main-copy {
    width: min(47rem, 58%);
    margin-top: clamp(4rem, 5.25vw, 6.25rem);
  }
  h2 {
    max-width: 12ch;
    margin: 0 0 -0.08em;
    padding-bottom: 0.08em;
    font-family: var(--font-home-heading);
    font-size: var(--home-heading-size-compact);
    font-weight: var(--font-home-heading-weight);
    letter-spacing: var(--font-home-heading-tracking);
    line-height: 0.96;
    overflow-wrap: normal;
    text-wrap: balance;
  }

  .intro {
    max-width: 40rem;
    margin: clamp(2rem, 2vw, 2.5rem) 0 0;
    color: rgba(233, 239, 248, 0.7);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1rem, 1vw, 1.18rem);
    font-weight: 500;
    line-height: 1.58;
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: clamp(3rem, 3.75vw, 4.5rem);
    border-top: 1px solid rgba(210, 225, 248, 0.2);
  }
  .metrics article {
    min-width: 0;
    padding: clamp(1.65rem, 1.75vw, 2rem) 1.8rem 0 0;
  }
  .metrics article + article {
    padding-left: 1.6rem;
    border-left: 1px solid rgba(210, 225, 248, 0.2);
  }
  .metrics strong {
    display: block;
    color: #fff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.8rem, 3.75vw, 4.8rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
    white-space: nowrap;
  }
  .metrics article:first-child strong {
    color: #3978ff;
    text-shadow: 0 0 2.5rem rgba(39, 103, 255, 0.24);
  }
  .metrics h3 {
    margin: 0.8rem 0 0;
    font:
      700 0.76rem/1.2 "Space Grotesk",
      var(--font-display);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }
  .metrics p {
    max-width: 19rem;
    margin: 0.65rem 0 0;
    color: rgba(233, 239, 248, 0.56);
    font:
      500 0.86rem/1.45 "Manrope",
      var(--font-body);
  }
  .mobile-image {
    display: none;
  }
  .process {
    margin-top: clamp(3.75rem, 4.5vw, 5.5rem);
    border: 1px solid rgba(207, 222, 244, 0.2);
    background: rgba(6, 11, 18, 0.84);
    backdrop-filter: blur(12px);
  }
  .process ol {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .process li {
    position: relative;
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    align-items: center;
    gap: clamp(0.75rem, 1vw, 1.2rem);
    min-width: 0;
    min-height: clamp(10rem, 9vw, 11.5rem);
    padding: clamp(1.4rem, 1.6vw, 1.8rem) clamp(1rem, 1.35vw, 1.6rem);
  }
  .process li + li {
    border-left: 1px solid rgba(207, 222, 244, 0.14);
  }
  .number {
    align-self: start;
    padding-top: 0.2rem;
    color: #3978ff;
    font:
      500 clamp(0.9rem, 1vw, 1.12rem) / 1 "Space Grotesk",
      var(--font-display);
  }
  .step-content {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    min-width: 0;
  }
  .step-content svg {
    width: clamp(3.75rem, 4vw, 4.75rem);
    height: clamp(3.75rem, 4vw, 4.75rem);
    color: rgba(224, 228, 232, 0.78);
    fill: none;
  }
  .process strong {
    width: 100%;
    min-width: 0;
    max-width: 12rem;
    color: rgba(245, 248, 252, 0.82);
    font:
      500 clamp(0.82rem, 0.82vw, 0.96rem) / 1.35 "Manrope",
      var(--font-body);
    text-align: center;
    overflow-wrap: anywhere;
  }
  .process li:not(:last-child)::after {
    position: absolute;
    top: 50%;
    right: -0.27rem;
    z-index: 1;
    width: 0.48rem;
    height: 0.48rem;
    border-top: 1px solid rgba(217, 225, 237, 0.42);
    border-right: 1px solid rgba(217, 225, 237, 0.42);
    background: #080d15;
    content: "";
    transform: translateY(-50%) rotate(45deg);
  }
  @media (max-width: 900px) {
    .image-layer {
      inset-left: 24%;
    }
    .main-copy {
      width: min(42rem, 72%);
    }
  }
  @media (max-width: 760px) {
    .manufacturing {
      min-height: 0;
    }
    .image-layer {
      display: none;
    }
    .blueprint {
      mask-image: linear-gradient(180deg, #000, transparent 46%);
    }
    .shell {
      padding: 5.75rem clamp(1.25rem, 5.5vw, 2rem) 5rem;
    }
    .chapter {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
    .chapter p:last-child {
      display: none;
    }
    .chapter > span {
      width: 100%;
    }
    .main-copy {
      width: 100%;
      margin-top: 3rem;
    }
    h2 {
      font-size: var(--home-heading-size-mobile);
    }
    .metrics {
      grid-template-columns: 1fr;
      gap: 1.15rem;
      margin-top: 2.75rem;
      border: 0;
    }
    .metrics article,
    .metrics article + article {
      padding: 1.5rem;
      border: 1px solid rgba(210, 225, 248, 0.18);
      background: rgba(255, 255, 255, 0.025);
    }
    .metrics strong {
      font-size: clamp(2.55rem, 12vw, 3.8rem);
    }
    .mobile-image {
      position: relative;
      display: block;
      overflow: hidden;
      height: clamp(14rem, 68vw, 19rem);
      margin: 1.25rem 0 0;
      border: 1px solid rgba(210, 225, 248, 0.18);
    }
    .mobile-image::after {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(5, 9, 15, 0.15),
        transparent 55%,
        rgba(5, 9, 15, 0.55)
      );
      content: "";
    }
    .mobile-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: right center;
      filter: saturate(0.78) contrast(1.05);
    }
    .process {
      margin-top: 1.75rem;
    }
    .process ol {
      grid-template-columns: 1fr;
    }
    .process li {
      grid-template-columns: 2.25rem 3rem minmax(0, 1fr);
      align-items: center;
      min-height: 5rem;
      padding: 1rem 1.15rem;
    }
    .process li + li {
      border-top: 1px solid rgba(207, 222, 244, 0.14);
      border-left: 0;
    }
    .number {
      align-self: center;
      padding-top: 0;
    }
    .step-content {
      display: contents;
    }
    .step-content svg {
      width: 2.5rem;
      height: 2.5rem;
    }
    .process strong {
      max-width: none;
      text-align: left;
    }
    .process li::after {
      display: none;
    }
  }
</style>
