---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type TimelineItem = {
  year: string;
  title: string;
  text: string;
};

type ProofItem = {
  value: string;
  label: string;
};

type Props = {
  content: {
    title: string;
    body: string;
    cta: string;
    proof: ProofItem[];
    timeline: TimelineItem[];
    certificate: {
      kicker: string;
      title: string;
      text: string;
    };
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/story/", currentLocale);
---

<section class="evolution-section" aria-labelledby="evolution-title">
  <div class="evolution-shell">
    <div class="evolution-intro">
      <h2 id="evolution-title" data-reveal>{content.title}</h2>
      <p data-reveal style="--reveal-delay: 90ms">{content.body}</p>
      <a class="home-text-link" href={ctaHref} data-reveal style="--reveal-delay: 160ms">
        <span>{content.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <aside class="evolution-evidence" aria-label="BELES operating evidence" data-reveal>
      <div class="evidence-media" aria-hidden="true">
        <img
          src="/img/hero/beles-hero-desktop.webp"
          alt=""
          width="2048"
          height="1024"
          loading="lazy"
        />
      </div>
      {
        content.proof.map((item, index) => (
          <article style={`--reveal-delay: ${index * 80}ms`}>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))
      }
    </aside>

    <ol
      class="timeline"
      aria-label="BELES evolution timeline"
      data-reveal
      style="--reveal-delay: 120ms"
    >
      {
        content.timeline.map((item, index) => (
          <li
            class:list={["timeline-item", { "is-highlight": index === 3 }]}
            style={`--reveal-delay: ${index * 70}ms`}
          >
            <time>{item.year}</time>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <aside
      class="certificate-fragment"
      aria-label={content.certificate.kicker}
      data-reveal
      style="--reveal-delay: 180ms"
    >
      <div>
        <span>{content.certificate.kicker}</span>
        <strong>{content.certificate.title}</strong>
        <p>{content.certificate.text}</p>
      </div>
    </aside>
  </div>
</section>

<style>
  .evolution-section {
    position: relative;
    overflow: clip;
    background:
      radial-gradient(circle at 12% 12%, rgba(12, 67, 223, 0.08), transparent 27rem),
      linear-gradient(180deg, #e9eef4 0%, #f7f8fa 100%);
    color: #101722;
  }

  .evolution-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(20rem, 0.56fr);
    gap: clamp(2rem, 4vw, 4.5rem);
    width: min(100% - (var(--container-gutter) * 2), var(--container-max));
    margin-inline: auto;
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  .evolution-intro {
    max-width: 52rem;
  }

  .evolution-intro h2 {
    max-width: 13ch;
    margin: 0;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(3rem, 6.5vw, 6.8rem);
    font-weight: 500;
    letter-spacing: -0.048em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .evolution-intro p {
    max-width: 43rem;
    margin: 1.6rem 0 0;
    color: rgba(16, 23, 34, 0.68);
    font-size: clamp(1rem, 1.15vw, 1.14rem);
    font-weight: 520;
    line-height: 1.62;
  }

  .home-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    margin-top: 1.75rem;
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.045em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .home-text-link span:last-child {
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.2rem);
  }

  .evolution-evidence {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-content: start;
    gap: 0;
    overflow: hidden;
    border: 1px solid rgba(37, 43, 50, 0.13);
    background: #121821;
    color: #fff;
  }

  .evidence-media {
    position: relative;
    grid-column: 1 / -1;
    min-height: clamp(12rem, 18vw, 18rem);
    overflow: hidden;
  }

  .evidence-media::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(18, 24, 33, 0.06), #121821 92%),
      linear-gradient(90deg, rgba(18, 24, 33, 0.12), rgba(18, 24, 33, 0.72));
    content: "";
  }

  .evidence-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% center;
    filter: saturate(0.55) contrast(1.05);
    opacity: 0.72;
  }

  .evolution-evidence article {
    position: relative;
    display: grid;
    gap: 0.55rem;
    min-height: 9rem;
    padding: 1.15rem;
    border-top: 1px solid rgba(247, 248, 250, 0.13);
  }

  .evolution-evidence article + article {
    border-left: 1px solid rgba(247, 248, 250, 0.13);
  }

  .evolution-evidence strong {
    display: block;
    color: #8fa6ff;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.2rem, 3.7vw, 4rem);
    font-weight: 560;
    letter-spacing: -0.045em;
    line-height: 0.92;
  }

  .evolution-evidence span {
    display: block;
    margin-top: 0.65rem;
    color: rgba(247, 248, 250, 0.66);
    font-size: 0.9rem;
    font-weight: 560;
    line-height: 1.42;
  }

  .timeline {
    position: relative;
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) repeat(4, minmax(0, 0.86fr));
    gap: clamp(0.75rem, 1.3vw, 1.1rem);
    margin: clamp(2.5rem, 5vw, 5rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .timeline::before {
    position: absolute;
    top: 5.6rem;
    right: 0;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(12, 67, 223, 0.42), rgba(37, 43, 50, 0.12));
    content: "";
  }

  .timeline-item {
    position: relative;
    display: grid;
    align-content: start;
    min-height: 25rem;
    overflow: hidden;
    border: 1px solid rgba(37, 43, 50, 0.12);
    background: rgba(255, 255, 255, 0.42);
    padding: clamp(1rem, 1.6vw, 1.4rem);
  }

  .timeline-item::before {
    position: absolute;
    top: 5.32rem;
    left: clamp(1rem, 1.6vw, 1.4rem);
    width: 0.62rem;
    height: 0.62rem;
    border: 1px solid rgba(12, 67, 223, 0.72);
    background: #f7f8fa;
    content: "";
    transform: rotate(45deg);
  }

  .timeline-item time {
    color: rgba(16, 23, 34, 0.92);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.6rem, 4.6vw, 5.4rem);
    font-weight: 560;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .timeline-item div {
    margin-top: auto;
  }

  .timeline-item h3 {
    margin: 0;
    color: #111722;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(1rem, 1.22vw, 1.22rem);
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.16;
  }

  .timeline-item p {
    max-width: 18rem;
    margin: 0.72rem 0 0;
    color: rgba(16, 23, 34, 0.62);
    font-size: 0.88rem;
    font-weight: 520;
    line-height: 1.52;
  }

  .timeline-item.is-highlight {
    background: linear-gradient(135deg, rgba(12, 67, 223, 0.14), rgba(255, 255, 255, 0.72)), #fff;
    color: #0c43df;
  }

  .timeline-item.is-highlight::after {
    position: absolute;
    inset: auto -10% -18% auto;
    z-index: 0;
    width: min(20rem, 94%);
    height: 12rem;
    border: 1px solid rgba(12, 67, 223, 0.18);
    background: rgba(12, 67, 223, 0.08);
    transform: skewX(-18deg);
    content: "";
  }

  .timeline-item.is-highlight > * {
    position: relative;
    z-index: 1;
  }

  .certificate-fragment {
    grid-column: 1 / -1;
    justify-self: end;
    width: min(100%, 42rem);
    margin-top: -2.2rem;
    padding: 0.6rem;
    border: 1px solid rgba(37, 43, 50, 0.14);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.84), rgba(220, 227, 236, 0.52)),
      repeating-linear-gradient(0deg, rgba(37, 43, 50, 0.05) 0 1px, transparent 1px 0.62rem);
    box-shadow: 0 1.5rem 4rem rgba(37, 43, 50, 0.1);
  }

  .certificate-fragment div {
    padding: clamp(1.35rem, 2.4vw, 2rem);
    border: 1px solid rgba(37, 43, 50, 0.1);
    background: rgba(255, 255, 255, 0.34);
  }

  .certificate-fragment span {
    display: block;
    color: rgba(16, 23, 34, 0.48);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
  }

  .certificate-fragment strong {
    display: block;
    margin-top: 1.2rem;
    color: #111722;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(1.35rem, 2vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .certificate-fragment p {
    margin: 0.95rem 0 0;
    color: rgba(16, 23, 34, 0.64);
    font-size: 0.92rem;
    line-height: 1.52;
  }

  @media (max-width: 1000px) {
    .evolution-shell {
      grid-template-columns: 1fr;
    }

    .evolution-evidence {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .timeline {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .timeline::before {
      top: 0;
      bottom: 0;
      left: 0.18rem;
      width: 1px;
      height: auto;
    }

    .timeline-item {
      min-height: 0;
      padding: 1.2rem 1.2rem 1.2rem 2rem;
    }

    .timeline-item::before {
      top: 0.45rem;
      left: 0;
    }

    .timeline-item div {
      margin-top: 0.9rem;
    }

    .timeline-item.is-highlight::after {
      inset: -0.75rem 0 -0.75rem 1.1rem;
      width: auto;
      height: auto;
    }

    .certificate-fragment {
      justify-self: stretch;
      margin-top: 1rem;
    }
  }

  @media (max-width: 620px) {
    .evolution-evidence {
      grid-template-columns: 1fr;
    }

    .evolution-evidence article + article {
      border-left: 0;
    }

    .evolution-intro h2 {
      font-size: clamp(2.75rem, 13vw, 4.2rem);
    }
  }
</style>
