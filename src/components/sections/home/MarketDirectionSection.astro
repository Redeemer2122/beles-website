---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type Props = {
  content: {
    title: string;
    body: string;
    cta: string;
    origin: string;
    regions: string[];
    proof: string[];
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/about/", currentLocale);
---

<section class="market-section" aria-labelledby="market-title">
  <div class="market-shell">
    <div class="market-map" aria-label="BELES regional direction">
      <div class="corridor-title" data-reveal>
        <span>{content.origin}</span>
      </div>
      <div class="corridor-line" aria-hidden="true">
        <span data-reveal="line"></span>
      </div>
      <div class="region-cloud" aria-label="Target regional markets">
        {
          content.regions.map((region, index) => (
            <span
              class={`region-label region-${index + 1}`}
              data-reveal
              style={`--reveal-delay: ${index * 70}ms`}
            >
              {region}
            </span>
          ))
        }
      </div>
    </div>

    <div class="market-copy">
      <h2 id="market-title" data-reveal>{content.title}</h2>
      <p data-reveal style="--reveal-delay: 90ms">{content.body}</p>
      <ul aria-label="Market direction proof points">
        {
          content.proof.map((item, index) => (
            <li data-reveal style={`--reveal-delay: ${150 + index * 60}ms`}>
              {item}
            </li>
          ))
        }
      </ul>
      <a class="home-text-link" href={ctaHref} data-reveal style="--reveal-delay: 320ms">
        <span>{content.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .market-section {
    position: relative;
    overflow: clip;
    background:
      radial-gradient(circle at 18% 24%, rgba(12, 67, 223, 0.08), transparent 26rem),
      linear-gradient(180deg, #e9eef4 0%, #f7f8fa 100%);
    color: #101722;
  }

  .market-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(21rem, 0.82fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    width: min(100% - (var(--container-gutter) * 2), var(--container-max));
    margin-inline: auto;
    padding-block: clamp(5.5rem, 11vw, 11rem);
  }

  .market-map {
    position: relative;
    min-height: clamp(30rem, 42vw, 42rem);
    border: 1px solid rgba(37, 43, 50, 0.12);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(217, 224, 234, 0.22)),
      repeating-linear-gradient(0deg, rgba(37, 43, 50, 0.045) 0 1px, transparent 1px 5.5rem);
  }

  .corridor-title {
    position: absolute;
    top: clamp(1.4rem, 3vw, 2.4rem);
    left: clamp(1.4rem, 3vw, 2.4rem);
    z-index: 2;
    max-width: 16rem;
  }

  .corridor-title span {
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4.4rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 0.9;
  }

  .corridor-line {
    position: absolute;
    right: clamp(1.4rem, 3vw, 2.4rem);
    bottom: 25%;
    left: clamp(1.4rem, 3vw, 2.4rem);
    height: 12rem;
    border-bottom: 1px solid rgba(12, 67, 223, 0.34);
    border-left: 1px solid rgba(12, 67, 223, 0.16);
  }

  .corridor-line span {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1px;
    background: rgba(12, 67, 223, 0.55);
    transform-origin: left center;
  }

  .region-cloud {
    position: absolute;
    right: clamp(1.4rem, 3vw, 2.4rem);
    bottom: clamp(1.4rem, 3vw, 2.4rem);
    left: clamp(1.4rem, 3vw, 2.4rem);
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .region-label {
    display: inline-flex;
    align-items: center;
    min-height: 3.2rem;
    border: 1px solid rgba(37, 43, 50, 0.12);
    background: rgba(255, 255, 255, 0.68);
    padding: 0.58rem 0.72rem;
    color: rgba(16, 23, 34, 0.74);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.72rem, 1vw, 0.9rem);
    font-weight: 650;
    line-height: 1;
  }

  .market-copy {
    align-self: center;
  }

  .market-copy h2 {
    max-width: 12ch;
    margin: 0;
    color: #111722;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(2.85rem, 5.7vw, 5.9rem);
    font-weight: 500;
    letter-spacing: -0.052em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .market-copy p {
    max-width: 37rem;
    margin: 1.55rem 0 0;
    color: rgba(16, 23, 34, 0.68);
    font-size: clamp(1rem, 1.12vw, 1.12rem);
    font-weight: 520;
    line-height: 1.62;
  }

  .market-copy ul {
    display: grid;
    gap: 0.75rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .market-copy li {
    padding-block: 0.8rem;
    border-top: 1px solid rgba(37, 43, 50, 0.14);
    color: rgba(16, 23, 34, 0.76);
    font-size: 0.92rem;
    font-weight: 620;
    line-height: 1.35;
  }

  .home-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    margin-top: 1.8rem;
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.045em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .home-text-link span:last-child {
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.2rem);
  }

  @media (max-width: 980px) {
    .market-shell {
      grid-template-columns: 1fr;
    }

    .market-map {
      min-height: 31rem;
      order: 2;
    }
  }

  @media (max-width: 620px) {
    .market-copy h2 {
      font-size: clamp(2.55rem, 12vw, 4rem);
    }

    .market-map {
      min-height: 34rem;
    }

    .corridor-line {
      height: 8rem;
    }

    .region-cloud {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
