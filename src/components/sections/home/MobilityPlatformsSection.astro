---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type PlatformPanel = {
  title: string;
  text: string;
  tags: string[];
  imageAlt: string;
};

type Props = {
  content: {
    meta: {
      index: string;
      label: string;
    };
    title: string;
    body: string;
    cta: string;
    panels: PlatformPanel[];
    taxonomy: string[];
    taxonomyLabel: string;
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/projects/", currentLocale);

const images = [
  {
    webp: "/img/mobility/mobility-urban-main.webp",
    fallback: "/img/mobility/mobility-urban-main.jpg",
    width: 1800,
    height: 1125,
  },
  {
    webp: "/img/mobility/mobility-electric-platform.webp",
    fallback: "/img/mobility/mobility-electric-platform.jpg",
    width: 1100,
    height: 620,
  },
  {
    webp: "/img/mobility/mobility-commercial-transport.webp",
    fallback: "/img/mobility/mobility-commercial-transport.jpg",
    width: 1100,
    height: 620,
  },
];

const taxonomyIcons = [
  "M12 3.1C9.2 6.8 6 10.4 6 14a6 6 0 1 0 12 0c0-3.6-3.2-7.2-6-10.9Z",
  "M7.5 11.4a3 3 0 1 1 3-3 3 3 0 0 1-3 3Zm9 0a3 3 0 1 1 3-3 3 3 0 0 1-3 3ZM3 20a4.5 4.5 0 0 1 9 0m0 0a4.5 4.5 0 0 1 9 0m-10.5-7.2a4 4 0 0 1 3 0",
  "M5 19 19 5m-8.5 0 1.8 1.8M7.5 8l1.8 1.8M4 11.5l1.8 1.8M13.7 3.7l6.6 6.6-10 10-6.6-6.6 10-10Z",
];

const compactIcons = [
  "M12 3.25 4.75 7.35v8.3L12 19.75l7.25-4.1v-8.3L12 3.25Zm.35 5.1-2.05 3.9h2.35l-1 3.4 3.15-4.85h-2.55l1.1-2.45Z",
  "M5.2 14.6V9.2h9.4v5.4M14.6 11.1h3.2l2 2.5v1M7.2 17.7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10.3 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM3.8 14.6h2m12.7 0h1.7",
];
---

<section class="platforms-section" aria-labelledby="platforms-title">
  <div class="platforms-shell">
    <div class="platforms-meta" data-reveal>
      <p>
        <span>{content.meta.index}</span>
        <span aria-hidden="true">/</span>
        <span>{content.meta.label}</span>
      </p>
      <span class="platforms-meta-line" aria-hidden="true"></span>
    </div>

    <div class="platforms-heading">
      <h2 id="platforms-title" data-reveal style="--reveal-delay: 60ms">{content.title}</h2>
      <div class="platforms-intro" data-reveal style="--reveal-delay: 130ms">
        <p>{content.body}</p>
        <a class="home-text-link" href={ctaHref}>
          <span>{content.cta}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <div class="platform-board">
      <article
        class="platform-card platform-card-feature"
        data-reveal
        style="--reveal-delay: 180ms"
      >
        <div class="feature-image">
          <picture>
            <source srcset={images[0].webp} type="image/webp" />
            <img
              src={images[0].fallback}
              alt={content.panels[0].imageAlt}
              width={images[0].width}
              height={images[0].height}
              loading="lazy"
            />
          </picture>
        </div>
        <div class="feature-copy">
          <span class="card-index">01</span>
          <h3>{content.panels[0].title}</h3>
          <p>{content.panels[0].text}</p>
        </div>
        <ul class="tag-list tag-list-feature" aria-label={`${content.panels[0].title} tags`}>
          {content.panels[0].tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </article>

      <div class="platform-stack">
        {
          content.panels.slice(1).map((panel, index) => {
            const image = images[index + 1];
            return (
              <article
                class={`platform-card platform-card-compact platform-card-${index + 2}`}
                data-reveal
                style={`--reveal-delay: ${260 + index * 90}ms`}
              >
                <div class="compact-copy">
                  <svg class="compact-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d={compactIcons[index]} />
                  </svg>
                  <span class="card-index">{String(index + 2).padStart(2, "0")}</span>
                  <h3>{panel.title}</h3>
                  <p>{panel.text}</p>
                  <ul class="tag-list" aria-label={`${panel.title} tags`}>
                    {panel.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                </div>
                <div class="compact-visual">
                  <span class="blueprint-grid" aria-hidden="true" />
                  <picture>
                    <source srcset={image.webp} type="image/webp" />
                    <img
                      src={image.fallback}
                      alt={panel.imageAlt}
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                    />
                  </picture>
                </div>
              </article>
            );
          })
        }
      </div>

      <ul
        class="platform-taxonomy"
        aria-label={content.taxonomyLabel}
        data-reveal
        style="--reveal-delay: 420ms"
      >
        {
          content.taxonomy.map((item, index) => (
            <li>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={taxonomyIcons[index]} />
              </svg>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .platforms-section {
    --platforms-blue: #0b5cff;
    --platforms-ink: #101722;
    --platforms-muted: rgba(16, 23, 34, 0.68);
    --platforms-line: rgba(16, 23, 34, 0.145);
    --platforms-serif: Georgia, "Times New Roman", Times, serif;
    position: relative;
    overflow: clip;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0) 17rem),
      radial-gradient(ellipse at 88% 20%, rgba(12, 67, 223, 0.045), transparent 38rem),
      linear-gradient(180deg, #f7f9fc 0%, #eef3f8 56%, #f7f9fb 100%);
    border-top: 1px solid rgba(16, 23, 34, 0.1);
    color: var(--platforms-ink);
  }

  .platforms-shell {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    width: 100%;
    margin-inline: auto;
    padding: clamp(4.8rem, 6.6vw, 6.8rem) clamp(2rem, 4.4vw, 5.5rem) clamp(4.4rem, 6.4vw, 6.7rem);
  }

  .platforms-meta {
    display: grid;
    grid-template-columns: auto minmax(3rem, 1fr);
    align-items: center;
    gap: clamp(1rem, 2vw, 1.8rem);
  }

  .platforms-meta p {
    display: flex;
    flex-wrap: wrap;
    gap: 0.58rem;
    align-items: center;
    margin: 0;
    color: rgba(16, 23, 34, 0.74);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.72rem, 0.68vw, 0.84rem);
    font-weight: 800;
    letter-spacing: 0.2em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .platforms-meta p span:first-child {
    color: var(--platforms-blue);
  }

  .platforms-meta-line {
    position: relative;
    display: block;
    height: 1px;
    background: rgba(16, 23, 34, 0.18);
  }

  .platforms-meta-line::after {
    position: absolute;
    top: -1px;
    left: 0;
    width: clamp(2.1rem, 3.2vw, 3.8rem);
    height: 3px;
    background: var(--platforms-blue);
    border-radius: 999px;
    content: "";
  }

  .platforms-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.25rem, 2vw, 2rem);
    align-items: start;
    margin-top: clamp(2.4rem, 3.5vw, 3.6rem);
  }

  .platforms-heading > * {
    min-width: 0;
  }

  .platforms-heading h2 {
    max-width: min(24ch, 100%);
    margin: 0;
    font-family: var(--font-home-heading);
    font-size: var(--home-heading-size-wide);
    font-weight: var(--font-home-heading-weight);
    letter-spacing: var(--font-home-heading-tracking);
    line-height: 0.98;
    overflow-wrap: normal;
    padding-bottom: 0.06em;
    text-wrap: balance;
  }

  .platforms-intro {
    max-width: min(47rem, 100%);
    padding-bottom: 0;
  }

  .platforms-intro p {
    margin: 0;
    color: var(--platforms-muted);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1.08rem, 1.02vw, 1.28rem);
    font-weight: 520;
    line-height: 1.5;
  }

  .home-text-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.95rem;
    margin-top: clamp(1.1rem, 1.6vw, 1.55rem);
    color: var(--platforms-blue);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1rem, 0.9vw, 1.12rem);
    font-weight: 650;
    letter-spacing: 0.01em;
    line-height: 1;
    text-decoration: none;
  }

  .home-text-link::after {
    position: absolute;
    right: 1.85rem;
    bottom: -0.45rem;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0.7);
    transform-origin: left center;
    transition: transform 260ms var(--ease-out);
    content: "";
  }

  .home-text-link span:last-child {
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.2rem);
  }

  .home-text-link:hover::after,
  .home-text-link:focus-visible::after {
    transform: scaleX(1);
  }

  .platform-board {
    display: grid;
    grid-template-columns: minmax(0, 1.39fr) minmax(31rem, 1fr);
    gap: clamp(0.95rem, 1vw, 1.25rem);
    margin-top: clamp(2rem, 2.6vw, 3.1rem);
  }

  .platform-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--platforms-line);
    border-radius: clamp(0.68rem, 0.65vw, 0.9rem);
    box-shadow: 0 1rem 3.2rem rgba(35, 45, 62, 0.055);
  }

  .platform-card-feature {
    display: grid;
    min-height: clamp(32rem, 31.5vw, 39rem);
    background: #101722;
    color: #ffffff;
  }

  .platform-card-feature::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        90deg,
        rgba(8, 12, 18, 0.48) 0%,
        rgba(8, 12, 18, 0.25) 26%,
        rgba(8, 12, 18, 0.04) 43%,
        rgba(8, 12, 18, 0) 55%
      ),
      linear-gradient(90deg, rgba(8, 12, 18, 0.16) 0%, rgba(8, 12, 18, 0) 38%);
    content: "";
  }

  .platform-card-feature::after {
    position: absolute;
    top: clamp(2rem, 3vw, 3.1rem);
    left: clamp(1.8rem, 3vw, 2.8rem);
    z-index: 2;
    width: 3.2rem;
    height: 2px;
    background: var(--platforms-blue);
    content: "";
  }

  .feature-image,
  .feature-image picture,
  .feature-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .feature-image img {
    object-fit: cover;
    object-position: 58% center;
    filter: saturate(1) contrast(1.01) brightness(1.24);
    transition: transform 900ms var(--ease-out);
  }

  .platform-card-feature:hover .feature-image img {
    transform: scale(1.035);
  }

  .feature-copy {
    position: relative;
    z-index: 2;
    align-self: start;
    max-width: min(31rem, 52%);
    padding: clamp(4.6rem, 4.8vw, 5.8rem) clamp(2rem, 2.6vw, 3.1rem) 1rem;
  }

  .card-index {
    display: block;
    color: var(--platforms-blue);
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1;
  }

  .feature-copy h3,
  .compact-copy h3 {
    margin: 0.95rem 0 0;
    font-family: var(--platforms-serif);
    font-weight: 400;
    letter-spacing: -0.045em;
    line-height: 0.96;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  .feature-copy h3 {
    color: #ffffff;
    font-size: clamp(3.1rem, 3.5vw, 4.65rem);
  }

  .feature-copy p {
    max-width: 23rem;
    margin: 1.1rem 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1rem, 0.92vw, 1.13rem);
    font-weight: 570;
    line-height: 1.48;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.48rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    border: 1px solid rgba(16, 23, 34, 0.18);
    border-radius: 0.22rem;
    background: rgba(255, 255, 255, 0.68);
    padding: 0.55rem 0.7rem;
    color: rgba(16, 23, 34, 0.76);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.72rem, 0.68vw, 0.82rem);
    font-weight: 760;
    line-height: 1.05;
    overflow-wrap: anywhere;
  }

  .tag-list-feature {
    position: relative;
    z-index: 2;
    align-self: end;
    padding: 0 clamp(2rem, 2.6vw, 3.1rem) clamp(1.75rem, 2.1vw, 2.45rem);
  }

  .tag-list-feature li {
    border-color: rgba(255, 255, 255, 0.54);
    background: rgba(9, 14, 22, 0.28);
    color: rgba(255, 255, 255, 0.92);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
  }

  .platform-stack {
    display: grid;
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: clamp(0.95rem, 1vw, 1.25rem);
  }

  .platform-card-compact {
    display: block;
    min-height: clamp(15.4rem, 14.6vw, 18.7rem);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 247, 252, 0.72)), #f7f9fb;
  }

  .platform-card-compact::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.9), transparent 58%),
      radial-gradient(circle at 74% 48%, rgba(12, 67, 223, 0.035), transparent 16rem);
    content: "";
  }

  .compact-copy {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    box-sizing: border-box;
    width: min(57%, 21rem);
    min-width: 0;
    padding: clamp(1.4rem, 1.65vw, 2rem) clamp(1.15rem, 1.42vw, 1.72rem)
      clamp(1.3rem, 1.5vw, 1.8rem) clamp(1.5rem, 1.7vw, 2rem);
  }

  .compact-icon {
    width: clamp(1.8rem, 1.75vw, 2.25rem);
    height: clamp(1.8rem, 1.75vw, 2.25rem);
    margin-bottom: clamp(0.75rem, 0.85vw, 1rem);
    color: var(--platforms-blue);
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.22;
  }

  .compact-copy h3 {
    color: var(--platforms-ink);
    font-size: clamp(1.9rem, 1.72vw, 2.55rem);
  }

  .compact-copy p {
    max-width: 18.5rem;
    margin: 0.78rem 0 0;
    color: var(--platforms-muted);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(0.94rem, 0.86vw, 1.05rem);
    font-weight: 560;
    line-height: 1.42;
  }

  .compact-copy .tag-list {
    margin-top: 1.1rem;
    padding-top: 0;
  }

  .compact-visual {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .compact-visual::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      90deg,
      #f7f9fb 0%,
      rgba(247, 249, 251, 0.97) 44%,
      rgba(247, 249, 251, 0.56) 57%,
      transparent 72%
    );
    content: "";
  }

  .compact-visual picture,
  .compact-visual img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .compact-visual img {
    position: relative;
    z-index: 1;
    object-fit: cover;
    object-position: right center;
    mix-blend-mode: normal;
    opacity: 1;
    filter: saturate(0.98) contrast(1.01);
  }

  .platform-taxonomy {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(16, 23, 34, 0.16);
    border-bottom: 1px solid rgba(16, 23, 34, 0.1);
    background: rgba(255, 255, 255, 0.18);
    list-style: none;
  }

  .platform-taxonomy li {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.65rem, 0.85vw, 0.9rem);
    min-height: clamp(3.65rem, 3.45vw, 4.5rem);
    padding: 0.75rem clamp(1rem, 1.5vw, 1.6rem);
    color: rgba(16, 23, 34, 0.83);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.86rem, 0.84vw, 1.04rem);
    font-weight: 720;
    line-height: 1.25;
    text-align: center;
  }

  .platform-taxonomy li + li {
    border-left: 1px solid rgba(16, 23, 34, 0.13);
  }

  .platform-taxonomy svg {
    flex: 0 0 auto;
    width: 1.2rem;
    height: 1.2rem;
    color: var(--platforms-blue);
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.6;
  }

  @media (max-width: 1100px) {
    .platforms-heading {
      grid-template-columns: 1fr;
      gap: 1.45rem;
    }

    .platforms-intro {
      max-width: 43rem;
    }

    .platform-board {
      grid-template-columns: 1fr;
    }

    .platform-card-feature {
      min-height: clamp(29rem, 62vw, 38rem);
    }
  }

  @media (max-width: 760px) {
    .platforms-shell {
      padding-block: clamp(5.5rem, 18vw, 7.5rem) clamp(4.4rem, 14vw, 6rem);
    }

    .platforms-meta {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .platforms-heading h2 {
      font-size: var(--home-heading-size-mobile);
    }

    .feature-copy {
      max-width: 100%;
    }

    .platform-card-compact {
      min-height: 0;
    }

    .compact-visual {
      position: relative;
      min-height: 13.5rem;
    }

    .compact-visual::after {
      background: linear-gradient(
        180deg,
        transparent 0%,
        rgba(247, 249, 251, 0.38) 54%,
        #f7f9fb 100%
      );
    }

    .compact-copy {
      width: 100%;
      min-height: 16rem;
      padding-top: 1.35rem;
    }

    .platform-taxonomy {
      grid-template-columns: 1fr;
    }

    .platform-taxonomy li {
      justify-content: flex-start;
      min-height: 4rem;
      text-align: left;
    }

    .platform-taxonomy li + li {
      border-top: 1px solid rgba(16, 23, 34, 0.13);
      border-left: 0;
    }
  }

  @media (max-width: 520px) {
    .platform-card {
      border-radius: 0.55rem;
    }

    .platform-card-feature {
      min-height: 32rem;
    }

    .feature-image img {
      object-position: 62% center;
    }

    .feature-copy {
      padding-top: 4.3rem;
    }

    .feature-copy h3 {
      font-size: clamp(2.1rem, 11vw, 3rem);
    }

    .tag-list-feature {
      align-content: end;
    }

    .compact-copy {
      min-height: 0;
      padding-bottom: 1.45rem;
    }

    .compact-visual {
      min-height: 11.5rem;
    }

    .platform-taxonomy {
      background: rgba(255, 255, 255, 0.28);
    }

    .platform-taxonomy li {
      min-height: 3.55rem;
      padding: 0.7rem 0.9rem;
      font-size: 0.9rem;
    }

    .tag-list li {
      padding: 0.5rem 0.6rem;
    }
  }
</style>
