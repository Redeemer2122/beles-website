---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type ProofItem = {
  value: string;
  label: string;
};

type Props = {
  content: {
    title: string;
    body: string;
    cta: string;
    proof: ProofItem[];
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/story/", currentLocale);
---

<section class="national-oem-section" aria-labelledby="national-oem-title">
  <div class="national-shell">
    <div class="proof-rail" aria-label="BELES national OEM proof points">
      {
        content.proof.map((item, index) => (
          <article class="proof-record" data-reveal style={`--reveal-delay: ${index * 80}ms`}>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))
      }
    </div>

    <div class="national-statement">
      <div class="metal-plane" aria-hidden="true">
        <span></span>
        <span></span>
      </div>
      <h2 id="national-oem-title" data-reveal>{content.title}</h2>
      <p data-reveal style="--reveal-delay: 90ms">{content.body}</p>
      <a class="home-text-link" href={ctaHref} data-reveal style="--reveal-delay: 160ms">
        <span>{content.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .national-oem-section {
    position: relative;
    overflow: clip;
    background: linear-gradient(180deg, #f4f6f9 0%, #eef2f6 100%), var(--color-paper);
    color: #101722;
  }

  .national-shell {
    display: grid;
    grid-template-columns: minmax(14rem, 0.72fr) minmax(0, 1.4fr);
    gap: clamp(2.5rem, 7vw, 8rem);
    width: min(100% - (var(--container-gutter) * 2), var(--container-max));
    margin-inline: auto;
    padding-block: clamp(6rem, 12vw, 13rem);
  }

  .proof-rail {
    display: grid;
    align-content: end;
    gap: 1.15rem;
    padding-top: clamp(1rem, 8vw, 8rem);
  }

  .proof-record {
    display: grid;
    gap: 0.48rem;
    padding-block: 1rem;
    border-top: 1px solid rgba(37, 43, 50, 0.16);
  }

  .proof-record strong {
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(1.22rem, 2vw, 1.9rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1;
  }

  .proof-record span {
    max-width: 19rem;
    color: rgba(16, 23, 34, 0.64);
    font-size: 0.88rem;
    font-weight: 560;
    line-height: 1.45;
  }

  .national-statement {
    position: relative;
    min-height: clamp(32rem, 52vw, 47rem);
    padding: clamp(2.5rem, 6vw, 5.5rem) 0 clamp(2rem, 5vw, 4rem);
  }

  .metal-plane {
    position: absolute;
    inset: 0 0 auto auto;
    z-index: 0;
    width: min(48vw, 44rem);
    height: min(52vw, 42rem);
    pointer-events: none;
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.88),
        rgba(214, 221, 230, 0.14) 54%,
        rgba(255, 255, 255, 0.72)
      ),
      repeating-linear-gradient(112deg, rgba(41, 70, 143, 0.08) 0 1px, transparent 1px 4.5rem);
    clip-path: polygon(18% 0, 100% 0, 82% 100%, 0 100%);
    opacity: 0.92;
  }

  .metal-plane span {
    position: absolute;
    display: block;
    background: rgba(12, 67, 223, 0.34);
  }

  .metal-plane span:first-child {
    top: 18%;
    right: 9%;
    width: 42%;
    height: 1px;
  }

  .metal-plane span:last-child {
    right: 24%;
    bottom: 17%;
    width: 1px;
    height: 38%;
  }

  .national-statement h2,
  .national-statement p,
  .national-statement a {
    position: relative;
    z-index: 1;
  }

  .national-statement h2 {
    max-width: 12ch;
    margin: 0;
    color: #111722;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(3.5rem, 8.2vw, 8.7rem);
    font-weight: 500;
    letter-spacing: -0.055em;
    line-height: 0.88;
    text-wrap: balance;
  }

  .national-statement p {
    max-width: 39rem;
    margin: clamp(1.6rem, 3vw, 2.4rem) 0 0;
    color: rgba(16, 23, 34, 0.72);
    font-size: clamp(1rem, 1.25vw, 1.2rem);
    font-weight: 520;
    line-height: 1.62;
    text-wrap: pretty;
  }

  .home-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    margin-top: 2rem;
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.045em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .home-text-link span:last-child {
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.2rem);
  }

  @media (max-width: 900px) {
    .national-shell {
      grid-template-columns: 1fr;
      gap: 2.25rem;
      padding-block: 5rem 6.5rem;
    }

    .proof-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      order: 2;
      padding-top: 0;
    }

    .national-statement {
      min-height: auto;
      padding-block: 1rem 2rem;
    }

    .metal-plane {
      width: 84vw;
      height: 24rem;
      opacity: 0.62;
    }
  }

  @media (max-width: 560px) {
    .proof-rail {
      grid-template-columns: 1fr;
    }

    .national-statement h2 {
      font-size: clamp(3rem, 15vw, 4.45rem);
      letter-spacing: -0.045em;
      line-height: 0.92;
    }
  }
</style>
