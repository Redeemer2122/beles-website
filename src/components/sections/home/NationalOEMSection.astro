---
import { getLocaleFromPathname, getLocalizedPath } from "../../../lib/navigation";

type ProofItem = {
  title: string;
  text: string;
};

type Props = {
  content: {
    eyebrow: string;
    origin: string;
    certification: string;
    title: string;
    titleLines: string[];
    body: string;
    cta: string;
    proofLabel: string;
    proof: ProofItem[];
  };
};

const { content } = Astro.props;
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const ctaHref = getLocalizedPath("/story/", currentLocale);
const certificationParts = content.certification.split("K59");
const proof = content.proof;
---

<section class="national-oem-section" aria-labelledby="national-oem-title">
  <div class="national-shell">
    <div class="national-meta" data-reveal style="--reveal-delay: 80ms">
      <span class="national-meta__primary">{content.eyebrow}</span>
      <span class="national-meta__divider" aria-hidden="true"></span>
      <span>{content.origin}</span>
      <span class="national-meta__divider" aria-hidden="true"></span>
      <span>
        {certificationParts[0]}
        {
          certificationParts.length > 1 ? (
            <>
              <span class="national-blue">K59</span>
              {certificationParts.slice(1).join("K59")}
            </>
          ) : null
        }
      </span>
    </div>

    <div class="national-editorial">
      <div class="national-statement">
        <h2 id="national-oem-title" aria-label={content.title}>
          {
            content.titleLines.map((line, index) => (
              <span
                class="national-title-line"
                data-reveal
                style={`--reveal-delay: ${180 + index * 90}ms`}
              >
                {index === content.titleLines.length - 1 ? line.replace(/\.$/, "") : line}
                {index === content.titleLines.length - 1 ? (
                  <span class="national-title-dot">.</span>
                ) : null}
              </span>
            ))
          }
        </h2>

        <span class="national-statement__rule" aria-hidden="true"></span>

        <p data-reveal style="--reveal-delay: 560ms">{content.body}</p>

        <a class="home-text-link" href={ctaHref} data-reveal style="--reveal-delay: 650ms">
          <span>{content.cta}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="national-data" aria-label="National OEM certification details">
        <div class="national-ghost" aria-hidden="true">
          <span>BELES</span>
          <span class="national-dot-grid"></span>
        </div>

        <div class="national-wmi" data-reveal style="--reveal-delay: 420ms">
          <span class="national-panel-label">WMI</span>
          <strong aria-label="K59">
            <span class="national-wmi__letter">K</span>
            <span class="national-wmi__digits">59</span>
          </strong>
          <span class="national-wmi__rule" aria-hidden="true"></span>
          <span class="national-wmi__assigned">Assigned by</span>
          <span class="national-wmi__issuer">SAE International</span>
        </div>

        <div class="national-spec-grid" data-reveal style="--reveal-delay: 500ms">
          <article>
            <span class="national-panel-label">Founded</span>
            <strong>2012</strong>
          </article>
          <article>
            <span class="national-panel-label">Region</span>
            <strong>Central Asia / EAEU</strong>
          </article>
          <article>
            <span class="national-panel-label">Status</span>
            <strong>National OEM</strong>
          </article>
          <div class="national-mark" aria-hidden="true">
            <svg viewBox="0 0 220 220" role="img">
              <circle cx="110" cy="110" r="84"></circle>
              <circle cx="110" cy="110" r="100"></circle>
              <path d="M12 110H208"></path>
              <path d="M208 98V122"></path>
              <path
                class="national-mark__mountain"
                d="M48 150L80 110L95 132L111 96L142 150M73 133L88 116L101 138M105 122L116 136L126 120L168 150M130 118L142 99L173 150M143 120L154 132L160 121"
              ></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="proof-rail" aria-label={content.proofLabel}>
      {
        proof.map((item, index) => (
          <article class="proof-record" data-reveal style={`--reveal-delay: ${760 + index * 90}ms`}>
            <span class="proof-record__index">{String(index + 1).padStart(2, "0")}</span>
            <h3 aria-label={item.title}>
              {item.title.includes("K59") ? (
                <>
                  {item.title.split("K59")[0]}
                  <span class="national-proof-k59" aria-hidden="true">
                    <span>K</span>
                    <span>59</span>
                  </span>
                  {item.title.split("K59").slice(1).join("K59")}
                </>
              ) : (
                item.title
              )}
            </h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .national-oem-section {
    position: relative;
    box-sizing: border-box;
    overflow: clip;
    isolation: isolate;
    min-height: 100dvh;
    --national-blue: 0 77 190;
    --national-ink: 12 24 43;
    --national-muted: 74 78 88;
    --national-line: 198 202 207;
    --national-serif: Georgia, "Times New Roman", Times, serif;
    background:
      radial-gradient(circle at 25% 18%, rgb(255 255 255 / 0.92), transparent 30rem),
      radial-gradient(circle at 74% 44%, rgb(224 224 222 / 0.28), transparent 38rem),
      linear-gradient(118deg, #fbfaf8 0%, #f7f6f3 58%, #f3f2ef 100%);
    color: rgb(var(--national-ink));
  }

  .national-oem-section::before,
  .national-oem-section::after {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    content: "";
  }

  .national-oem-section::before {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.72), transparent 38%),
      linear-gradient(90deg, rgb(255 255 255 / 0.42), transparent 48%, rgb(0 0 0 / 0.025));
  }

  .national-oem-section::after {
    background-image:
      linear-gradient(rgb(var(--national-line) / 0.2) 1px, transparent 1px),
      linear-gradient(90deg, rgb(var(--national-line) / 0.16) 1px, transparent 1px);
    background-size:
      100% 24.4rem,
      24.2rem 100%;
    opacity: 0.11;
  }

  .national-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    width: 100%;
    min-height: 100dvh;
  }

  .national-meta {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) auto minmax(0, 0.75fr) auto minmax(0, 1.45fr);
    align-items: center;
    min-height: clamp(4.2rem, 5vw, 4.85rem);
    padding-inline: clamp(2rem, 3.45vw, 3.65rem);
    border-bottom: 1px solid rgb(var(--national-line) / 0.72);
    color: rgb(var(--national-ink) / 0.72);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.64rem, 0.72vw, 0.78rem);
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .national-meta > span:nth-child(3) {
    justify-self: center;
  }

  .national-meta > span:last-child {
    justify-self: end;
  }

  .national-meta__primary {
    justify-self: start;
  }

  .national-meta__primary,
  .national-blue {
    color: rgb(var(--national-blue));
  }

  .national-meta__divider {
    display: block;
    width: 1px;
    height: 1.8rem;
    background: rgb(var(--national-line) / 0.9);
  }

  .national-editorial {
    display: grid;
    grid-template-columns: minmax(30rem, 0.96fr) minmax(37rem, 1.04fr);
    align-items: center;
    gap: clamp(3rem, 4vw, 5.9rem);
    padding: clamp(2.05rem, 3.45vw, 3.25rem) clamp(2rem, 4.2vw, 4.55rem)
      clamp(2.35rem, 3.15vw, 3.15rem);
  }

  .national-statement {
    max-width: 45rem;
  }

  .national-statement h2 {
    overflow: visible;
    padding-bottom: 0.14em;
    margin: 0;
    color: rgb(var(--national-ink));
    font-family: var(--national-serif);
    font-size: clamp(4.38rem, 5.2vw, 6.42rem);
    font-weight: 400;
    letter-spacing: -0.052em;
    line-height: 0.96;
  }

  .national-title-line {
    display: block;
    overflow: visible;
    padding-bottom: 0.13em;
    margin-bottom: -0.13em;
    line-height: inherit;
  }

  .national-title-dot {
    color: rgb(var(--national-blue));
  }

  .national-statement__rule {
    display: block;
    width: 4.1rem;
    height: 1px;
    margin-top: clamp(1.55rem, 2.2vw, 2.3rem);
    background: rgb(var(--national-blue));
  }

  .national-statement p {
    max-width: 37.5rem;
    margin: clamp(1.6rem, 2vw, 2rem) 0 0;
    color: rgb(var(--national-muted) / 0.94);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1.02rem, 1.12vw, 1.22rem);
    font-weight: 500;
    letter-spacing: 0.012em;
    line-height: 1.43;
    text-wrap: pretty;
  }

  .home-text-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: clamp(2rem, 2.6vw, 2.55rem);
    color: rgb(var(--national-blue));
    font-family: "Manrope", var(--font-body);
    font-size: clamp(1rem, 1vw, 1.15rem);
    font-weight: 650;
    letter-spacing: 0.012em;
    line-height: 1;
    text-decoration: none;
  }

  .home-text-link::after {
    position: absolute;
    right: 2.05rem;
    bottom: -0.45rem;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0.72);
    transform-origin: left center;
    transition: transform 260ms var(--ease-out);
    content: "";
  }

  .home-text-link span:last-child {
    font-family: "Space Grotesk", var(--font-display);
    transition: transform 220ms var(--ease-out);
  }

  .home-text-link:hover::after,
  .home-text-link:focus-visible::after {
    transform: scaleX(1);
  }

  .home-text-link:hover span:last-child,
  .home-text-link:focus-visible span:last-child {
    transform: translateX(0.22rem);
  }

  .national-data {
    position: relative;
    display: grid;
    grid-template-columns: minmax(12.5rem, 0.68fr) minmax(29rem, 1.32fr);
    align-items: end;
    min-height: clamp(20rem, 23vw, 24rem);
    padding-top: clamp(8rem, 9vw, 9rem);
  }

  .national-ghost {
    position: absolute;
    top: -1.65rem;
    right: 0.3rem;
    left: 0.6rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 2rem;
    pointer-events: none;
  }

  .national-ghost > span:first-child {
    color: rgb(var(--national-ink) / 0.055);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(7rem, 11.45vw, 13.2rem);
    font-weight: 800;
    letter-spacing: 0.034em;
    line-height: 0.82;
    text-transform: uppercase;
    transform: scaleX(1.09);
    transform-origin: left center;
  }

  .national-dot-grid {
    width: clamp(4.25rem, 4.5vw, 4.75rem);
    height: clamp(4.25rem, 4.5vw, 4.75rem);
    margin-top: 2rem;
    background-image: radial-gradient(
      circle,
      rgb(var(--national-ink) / 0.28) 1.55px,
      transparent 1.65px
    );
    background-size: 0.73rem 0.73rem;
    opacity: 0.5;
  }

  .national-wmi {
    align-self: center;
    padding-top: clamp(0.2rem, 0.65vw, 0.85rem);
    padding-left: 1rem;
  }

  .national-panel-label,
  .national-wmi__assigned,
  .national-wmi__issuer {
    display: block;
    color: rgb(var(--national-blue));
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.68rem, 0.74vw, 0.82rem);
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .national-wmi strong {
    display: flex;
    align-items: baseline;
    margin-top: 0.65rem;
    color: rgb(var(--national-blue));
    font-family: var(--national-serif);
    font-size: clamp(5rem, 6.95vw, 8.25rem);
    font-weight: 400;
    font-variant-numeric: lining-nums;
    font-feature-settings: "lnum" 1;
    letter-spacing: -0.065em;
    line-height: 0.82;
  }

  .national-wmi__letter,
  .national-wmi__digits {
    display: inline-block;
    line-height: 0.82;
  }

  .national-wmi__digits {
    --national-wmi-digit-lift: -0.018em;
    margin-left: 0.018em;
    transform: translateY(var(--national-wmi-digit-lift));
  }

  .national-wmi__rule {
    display: block;
    width: min(7.8rem, 64%);
    height: 1px;
    margin-block: clamp(1.5rem, 2.05vw, 2.05rem);
    background: rgb(var(--national-blue));
  }

  .national-wmi__assigned {
    margin-bottom: 0.85rem;
    color: rgb(var(--national-blue));
  }

  .national-wmi__issuer {
    color: rgb(var(--national-blue));
    font-size: clamp(0.62rem, 0.66vw, 0.72rem);
    letter-spacing: 0.24em;
  }

  .national-spec-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    align-self: end;
    border-left: 1px solid rgb(var(--national-line) / 0.9);
    transform: translateY(1.7rem);
  }

  .national-spec-grid article {
    min-height: clamp(6.1rem, 6.25vw, 6.6rem);
    padding: clamp(1.25rem, 1.45vw, 1.55rem) clamp(1.55rem, 2.2vw, 2.35rem);
    border-bottom: 1px solid rgb(var(--national-line) / 0.95);
  }

  .national-spec-grid article:first-child {
    min-height: clamp(7.9rem, 8vw, 8.45rem);
  }

  .national-spec-grid article:first-child {
    border-top: 0;
  }

  .national-spec-grid article:last-of-type {
    border-bottom: 0;
  }

  .national-spec-grid strong {
    display: block;
    margin-top: 0.85rem;
    color: rgb(var(--national-blue));
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(1rem, 1.15vw, 1.28rem);
    font-weight: 600;
    letter-spacing: 0.11em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .national-spec-grid article:first-child strong {
    font-family: var(--national-serif);
    font-size: clamp(2.6rem, 3.15vw, 3.6rem);
    font-weight: 400;
    letter-spacing: -0.045em;
    line-height: 0.9;
    text-transform: none;
  }

  .national-mark {
    position: absolute;
    right: clamp(-1.05rem, -0.75vw, -0.25rem);
    top: clamp(-0.2rem, 0.25vw, 0.45rem);
    width: clamp(14.4rem, 16.2vw, 17rem);
    aspect-ratio: 1;
    color: rgb(var(--national-ink) / 0.105);
    pointer-events: none;
  }

  .national-mark svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .national-mark circle,
  .national-mark path {
    fill: none;
    stroke: currentColor;
    stroke-width: 0.8;
    vector-effect: non-scaling-stroke;
  }

  .national-mark__mountain {
    stroke-width: 2.25;
    opacity: 0.85;
  }

  .proof-rail {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr) minmax(0, 0.91fr) minmax(0, 1.07fr);
    height: 12.45rem;
    border-top: 1px solid rgb(var(--national-line) / 0.9);
    background: rgb(255 255 255 / 0.12);
  }

  .proof-record {
    position: relative;
    box-sizing: border-box;
    display: grid;
    align-content: start;
    gap: 0.62rem;
    min-height: 0;
    padding: clamp(1.8rem, 2.15vw, 2.35rem) clamp(2rem, 4.7vw, 4.9rem);
  }

  .proof-record + .proof-record {
    border-left: 1px solid rgb(var(--national-line) / 0.9);
  }

  .proof-record__index {
    color: rgb(var(--national-blue));
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.68rem, 0.72vw, 0.78rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1;
  }

  .proof-record h3 {
    margin: 0;
    color: rgb(var(--national-ink));
    font-family: var(--national-serif);
    font-size: clamp(1.7rem, 1.85vw, 2.15rem);
    font-weight: 400;
    font-variant-numeric: lining-nums;
    font-feature-settings: "lnum" 1;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .national-proof-k59 {
    display: inline-flex;
    align-items: baseline;
  }

  .national-proof-k59 span:last-child {
    margin-left: 0.035em;
  }

  .proof-record p {
    max-width: 18rem;
    margin: 0;
    color: rgb(var(--national-muted) / 0.86);
    font-family: "Manrope", var(--font-body);
    font-size: clamp(0.84rem, 0.86vw, 0.98rem);
    font-weight: 500;
    line-height: 1.42;
  }

  @media (max-width: 1180px) {
    .national-editorial {
      grid-template-columns: minmax(0, 0.95fr) minmax(28rem, 1.05fr);
      gap: 2.6rem;
    }

    .national-statement h2 {
      font-size: clamp(4.05rem, 6.4vw, 5.65rem);
    }

    .national-data {
      grid-template-columns: 0.82fr 1.18fr;
      min-height: 29rem;
    }
  }

  @media (max-width: 900px) {
    .national-shell {
      min-height: auto;
    }

    .national-oem-section {
      min-height: auto;
    }

    .national-meta {
      grid-template-columns: 1fr;
      gap: 0.55rem;
      align-items: start;
      padding-block: 1.3rem;
    }

    .national-meta > span:nth-child(3),
    .national-meta > span:last-child {
      justify-self: start;
    }

    .national-meta__divider {
      display: none;
    }

    .national-editorial {
      grid-template-columns: 1fr;
      gap: 3.2rem;
      padding-block: 4.5rem 3rem;
    }

    .national-statement h2 {
      max-width: 11.8ch;
      font-size: clamp(3.45rem, 11.8vw, 5rem);
      line-height: 0.99;
    }

    .national-statement p {
      max-width: 36rem;
    }

    .national-data {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 5.6rem;
    }

    .national-ghost {
      justify-content: flex-start;
    }

    .national-wmi {
      padding-top: 2rem;
      padding-bottom: 2.2rem;
    }

    .national-spec-grid {
      border-top: 1px solid rgb(var(--national-line) / 0.9);
      border-left: 0;
      transform: none;
    }

    .national-mark {
      right: 0;
      opacity: 0.72;
    }

    .proof-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      height: auto;
    }

    .proof-record:nth-child(odd) {
      border-left: 0;
    }

    .proof-record:nth-child(n + 3) {
      border-top: 1px solid rgb(var(--national-line) / 0.9);
    }
  }

  @media (max-width: 560px) {
    .national-editorial,
    .national-meta {
      padding-inline: 1.25rem;
    }

    .national-editorial {
      padding-block: 3.7rem 2.4rem;
    }

    .national-statement h2 {
      max-width: 11.6ch;
      font-size: clamp(3rem, 12.4vw, 3.85rem);
      line-height: 1;
    }

    .national-ghost > span:first-child {
      font-size: clamp(3.9rem, 19vw, 5.4rem);
    }

    .national-dot-grid {
      display: none;
    }

    .national-wmi strong {
      font-size: clamp(4.3rem, 22vw, 6.4rem);
    }

    .national-mark {
      width: 11rem;
      top: 2rem;
      opacity: 0.48;
    }

    .proof-rail {
      grid-template-columns: 1fr;
    }

    .proof-record {
      min-height: auto;
      padding: 1.35rem 1.25rem;
      border-left: 0;
    }

    .proof-record + .proof-record,
    .proof-record:nth-child(n + 3) {
      border-top: 1px solid rgb(var(--national-line) / 0.9);
      border-left: 0;
    }
  }
</style>
