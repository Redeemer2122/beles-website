---
const desktopHeroSrc = "/img/hero/beles-hero-desktop.webp";
const mobileHeroSrc = "/img/hero/beles-hero-mobile.webp";

const proofItems = [
  {
    value: "120+",
    label: "ENGINEERS",
  },
  {
    value: "3",
    label: "PLATFORMS",
  },
  {
    value: "50,000 m²",
    label: "FACILITY",
  },
  {
    value: "30+",
    label: "COUNTRIES",
  },
];
---

<section class="home-hero is-reveal-pending" aria-labelledby="home-hero-title" data-home-hero>
  <picture class="hero-background" aria-hidden="true">
    <source media="(max-width: 720px)" srcset={mobileHeroSrc} type="image/webp" />
    <img
      src={desktopHeroSrc}
      alt=""
      width="2048"
      height="1024"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-copy">
      <p class="hero-eyebrow hero-reveal">ENGINEERING • PRECISION • PURPOSE</p>
      <h1 id="home-hero-title" class="hero-reveal">Mobility, Engineered.</h1>
      <p class="hero-body hero-reveal">
        BELES develops advanced mobility platforms in Kyrgyzstan — built for the next era of
        industrial and urban transport.
      </p>
      <div class="hero-actions hero-reveal" aria-label="Homepage actions">
        <a class="primary-action" href="/projects/">
          <span>Explore Platform</span>
          <span class="action-arrow" aria-hidden="true">→</span>
        </a>
        <a class="secondary-action" href="/capabilities/">
          <span>Our Capabilities</span>
          <span class="action-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <aside class="proof-panel" aria-label="BELES capability proof points">
        {
          proofItems.map((item, index) => (
            <article class="proof-item hero-reveal" style={`--reveal-index: ${index}`}>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))
        }
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const hero = document.querySelector("[data-home-hero]");
    const image = hero?.querySelector(".hero-background img");

    if (!(hero instanceof HTMLElement) || !(image instanceof HTMLImageElement)) {
      return;
    }

    const fallbackDelay = 2000;
    const paintDelay = 140;
    let isImageReady = false;
    let isRevealReady = false;

    const afterPaint = () =>
      new Promise((resolve) => {
        requestAnimationFrame(() => {
          requestAnimationFrame(resolve);
        });
      });

    const releaseImage = () => {
      if (isImageReady) {
        return;
      }

      isImageReady = true;
      hero.classList.add("is-image-ready");
    };

    const releaseReveal = async () => {
      if (isRevealReady) {
        return;
      }

      isRevealReady = true;
      releaseImage();

      await afterPaint();
      window.setTimeout(() => {
        hero.classList.remove("is-reveal-pending");
        hero.classList.add("is-reveal-ready");
        document.dispatchEvent(new CustomEvent("home-hero:ready"));
      }, paintDelay);
    };

    const fallbackTimer = window.setTimeout(() => {
      releaseReveal();
    }, fallbackDelay);

    const loadHeroImage = async () => {
      try {
        if (!image.currentSrc) {
          await afterPaint();
        }

        if (image.complete && image.naturalWidth > 0) {
          if (typeof image.decode === "function") {
            await image.decode();
          }
        } else {
          await new Promise((resolve, reject) => {
            image.addEventListener("load", resolve, { once: true });
            image.addEventListener("error", reject, { once: true });
          });

          if (typeof image.decode === "function") {
            await image.decode();
          }
        }

        window.clearTimeout(fallbackTimer);
        releaseImage();
        releaseReveal();
      } catch {
        // Let the fallback timer release the content if loading or decoding fails.
      }
    };

    loadHeroImage();
  })();
</script>

<style>
  .home-hero {
    position: relative;
    isolation: isolate;
    min-height: max(100dvh, 54rem);
    margin-top: -6.1rem;
    overflow: clip;
    background: #f4f6f9;
    color: #05070a;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    display: block;
    pointer-events: none;
  }

  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform-origin: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(
        90deg,
        rgba(247, 249, 252, 0.76) 0%,
        rgba(247, 249, 252, 0.5) 22%,
        rgba(247, 249, 252, 0.06) 42%,
        rgba(247, 249, 252, 0) 68%
      ),
      linear-gradient(0deg, rgba(242, 245, 249, 0.24) 0%, rgba(242, 245, 249, 0) 34%),
      radial-gradient(ellipse at 18% 39%, rgba(255, 255, 255, 0.56), transparent 24rem);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(20rem, 37rem) minmax(0, 1fr);
    grid-template-rows: 1fr;
    width: 100%;
    min-height: max(100dvh, 54rem);
    padding: 8.65rem clamp(1.25rem, 4.45vw, 5.35rem) clamp(1.55rem, 3.2vw, 3rem);
  }

  .hero-copy {
    max-width: 37rem;
    align-self: start;
    padding-top: clamp(0.9rem, 4.2vh, 3.2rem);
  }

  .hero-eyebrow {
    margin: 0 0 1.15rem;
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.1;
  }

  h1 {
    max-width: 10.5ch;
    margin: 0;
    color: #111722;
    font-family: var(--font-home-heading);
    font-size: clamp(4.25rem, 5.35vw, 5.75rem);
    font-weight: var(--font-home-heading-weight);
    letter-spacing: var(--font-home-heading-tracking);
    line-height: 0.9;
    text-wrap: balance;
  }

  .hero-body {
    max-width: 30rem;
    margin: 1.25rem 0 0;
    color: rgba(17, 23, 34, 0.72);
    font-family: "Manrope", var(--font-body);
    font-size: 1.06rem;
    font-weight: 500;
    line-height: 1.62;
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 0.72rem;
    margin-top: 1.58rem;
  }

  .primary-action,
  .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.34rem;
    border-radius: 0.045rem;
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.035em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .primary-action {
    gap: 0.95rem;
    min-width: 10.85rem;
    padding-inline: 1.02rem 0.42rem;
    border: 1px solid rgba(8, 44, 154, 0.88);
    background: linear-gradient(180deg, #1152ef 0%, #0b3fce 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.26),
      inset 0 -1px 0 rgba(5, 22, 82, 0.28),
      0 0.18rem 0.42rem rgba(12, 67, 223, 0.08);
    color: #fff;
  }

  .secondary-action {
    gap: 0.9rem;
    min-width: 10.25rem;
    padding-inline: 0.98rem 0.42rem;
    border: 1px solid rgba(24, 30, 39, 0.2);
    background: rgba(255, 255, 255, 0.16);
    color: rgba(17, 23, 34, 0.86);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.26);
    backdrop-filter: blur(5px);
  }

  .action-arrow {
    display: inline-grid;
    place-items: center;
    width: 1.42rem;
    height: 100%;
    min-height: 1.36rem;
    border-left: 1px solid currentColor;
    padding-left: 0.4rem;
    aspect-ratio: 1;
    font-size: 0.82rem;
    line-height: 0;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .primary-action .action-arrow {
    border-left-color: rgba(255, 255, 255, 0.58);
  }

  .primary-action:hover,
  .primary-action:focus-visible,
  .secondary-action:hover,
  .secondary-action:focus-visible {
    transform: translateY(-1px);
  }

  .primary-action:hover,
  .primary-action:focus-visible {
    border-color: #1557ff;
    background: linear-gradient(180deg, #1a5bff 0%, #0e45dd 100%);
  }

  .secondary-action:hover,
  .secondary-action:focus-visible {
    border-color: rgba(12, 67, 223, 0.34);
    background: rgba(255, 255, 255, 0.3);
    color: #0c43df;
  }

  .primary-action:hover .action-arrow,
  .primary-action:focus-visible .action-arrow,
  .secondary-action:hover .action-arrow,
  .secondary-action:focus-visible .action-arrow {
    transform: translateX(0.16rem);
  }

  .proof-panel {
    display: grid;
    grid-template-columns: repeat(4, max-content);
    align-items: end;
    width: max-content;
    max-width: min(58vw, 42rem);
    margin-top: clamp(4.15rem, 7.8vh, 6rem);
    column-gap: clamp(1.05rem, 1.35vw, 1.62rem);
  }

  .proof-item {
    position: relative;
    min-width: clamp(4.6rem, 5.2vw, 6.35rem);
    padding-left: clamp(0.82rem, 1.05vw, 1.08rem);
  }

  .proof-item strong {
    display: block;
    color: #0c43df;
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(1.8rem, 2.15vw, 2.72rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 0.86;
    white-space: nowrap;
  }

  .proof-item span {
    display: block;
    margin-top: 0.62rem;
    color: rgba(17, 23, 34, 0.68);
    font-family: "Space Grotesk", var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .proof-item + .proof-item::before {
    position: absolute;
    top: 0.22rem;
    bottom: 0.12rem;
    left: 0;
    width: 1px;
    background: linear-gradient(
      180deg,
      rgba(12, 67, 223, 0.02),
      rgba(37, 43, 50, 0.18) 46%,
      rgba(37, 43, 50, 0.04)
    );
    content: "";
  }

  .hero-reveal {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .home-hero.is-reveal-pending .hero-background img {
      animation: hero-background-fallback 1ms linear 2000ms both;
      opacity: 0;
      transform: scale(1.018);
    }

    .home-hero.is-image-ready .hero-background img {
      opacity: 0.96;
      transform: scale(1.018);
    }

    .home-hero.is-reveal-ready .hero-background img {
      animation: hero-background-settle 1150ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .home-hero.is-reveal-pending .hero-reveal {
      animation: hero-reveal-fallback 1ms linear 2140ms both;
      opacity: 0;
      transform: translateY(0.72rem);
    }

    .home-hero.is-reveal-ready .hero-reveal {
      animation: hero-reveal-rise 720ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .home-hero.is-reveal-ready .hero-eyebrow {
      animation-delay: 280ms;
    }

    .home-hero.is-reveal-ready h1 {
      animation-delay: 390ms;
    }

    .home-hero.is-reveal-ready .hero-body {
      animation-delay: 520ms;
    }

    .home-hero.is-reveal-ready .hero-actions {
      animation-delay: 660ms;
    }

    .home-hero.is-reveal-ready .proof-item {
      animation-delay: calc(820ms + (var(--reveal-index) * 70ms));
    }

    @keyframes hero-background-settle {
      from {
        opacity: 0.96;
        transform: scale(1.018);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes hero-reveal-rise {
      from {
        opacity: 0;
        transform: translateY(0.72rem);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes hero-background-fallback {
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes hero-reveal-fallback {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-background img,
    .hero-reveal {
      animation: none;
      transform: none;
    }

    .home-hero.is-reveal-pending .hero-background img {
      opacity: 0;
    }

    .home-hero.is-image-ready .hero-background img {
      opacity: 1;
    }

    .home-hero.is-reveal-pending .hero-reveal {
      animation: hero-reveal-fallback 1ms linear 2140ms both;
      opacity: 0;
    }

    .home-hero.is-reveal-ready .hero-background img,
    .home-hero.is-reveal-ready .hero-reveal {
      opacity: 1;
    }

    .primary-action,
    .secondary-action,
    .action-arrow {
      transition-duration: 1ms;
    }

    @keyframes hero-reveal-fallback {
      to {
        opacity: 1;
      }
    }
  }

  @media (max-width: 1500px) {
    .proof-panel {
      grid-template-columns: repeat(2, max-content);
      max-width: 31rem;
      gap: 1.7rem clamp(1.7rem, 3vw, 2.45rem);
    }

    .proof-item {
      min-width: clamp(6.35rem, 12vw, 8.2rem);
    }

    .proof-item:nth-child(odd) {
      padding-left: 0;
    }

    .proof-item:nth-child(odd)::before {
      content: none;
    }
  }

  @media (max-width: 1240px) {
    .hero-content {
      grid-template-columns: minmax(20rem, 34rem) minmax(0, 1fr);
    }

    h1 {
      font-size: clamp(3.75rem, 4.7vw, 5rem);
    }

    .proof-panel {
      max-width: min(76vw, 43rem);
      column-gap: clamp(1.1rem, 2.15vw, 1.85rem);
    }

    .proof-item {
      min-width: clamp(4.85rem, 7.4vw, 6.75rem);
    }
  }

  @media (max-width: 960px) {
    .home-hero {
      min-height: 58rem;
    }

    .hero-background img {
      object-position: 60% center;
    }

    .hero-content {
      grid-template-columns: 1fr;
      min-height: 58rem;
      padding-top: 8rem;
    }

    .hero-copy {
      max-width: 34rem;
      padding-top: 1.25rem;
    }

    h1 {
      max-width: 12ch;
      font-size: 3.9rem;
    }

    .proof-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: min(100%, 34rem);
      max-width: 34rem;
      margin-top: 3rem;
      gap: 1.55rem 2.1rem;
      column-gap: 2.1rem;
    }

    .proof-item {
      min-width: 0;
    }

    .proof-item:nth-child(odd) {
      padding-left: 0;
    }

    .proof-item:nth-child(odd)::before {
      content: none;
    }
  }

  @media (max-width: 720px) {
    .home-hero {
      min-height: auto;
    }

    .hero-background img {
      object-position: center top;
    }

    .hero-overlay {
      background:
        linear-gradient(
          180deg,
          rgba(247, 249, 252, 0.92) 0%,
          rgba(247, 249, 252, 0.72) 31%,
          rgba(247, 249, 252, 0.2) 57%,
          rgba(247, 249, 252, 0.88) 83%,
          rgba(247, 249, 252, 0.96) 100%
        ),
        radial-gradient(ellipse at 12% 18%, rgba(255, 255, 255, 0.9), transparent 17rem);
    }

    .hero-content {
      min-height: 56rem;
      padding-bottom: 1.8rem;
    }

    .hero-copy {
      max-width: 28rem;
      padding-top: 0;
    }

    .hero-eyebrow {
      margin-bottom: 0.95rem;
      font-size: 0.7rem;
    }

    h1 {
      max-width: 10.4ch;
      font-size: 3rem;
      line-height: 0.96;
    }

    .hero-body {
      max-width: 23rem;
      margin-top: 1.1rem;
      font-size: 0.98rem;
      line-height: 1.52;
    }

    .hero-actions {
      display: grid;
      grid-template-columns: 1fr;
      max-width: 21rem;
      gap: 0.68rem;
      margin-top: 1.4rem;
    }

    .primary-action,
    .secondary-action {
      justify-content: space-between;
      width: 100%;
    }

    .proof-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 20rem;
      gap: 1.45rem 1.35rem;
    }

    .proof-item {
      padding-left: 1rem;
    }

    .proof-item strong {
      font-size: clamp(1.78rem, 9vw, 2.32rem);
    }

    .proof-item span {
      margin-top: 0.5rem;
      font-size: 0.58rem;
    }
  }

  @media (max-width: 420px) {
    h1 {
      font-size: 2.72rem;
    }

    .proof-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 18rem;
      gap: 1.35rem 1.05rem;
    }

    .proof-item {
      padding-left: 0.82rem;
    }

    .proof-item strong {
      font-size: clamp(1.58rem, 8vw, 2rem);
    }
  }
</style>
