---
type Props = {
  eyebrow: string;
  title: string;
  description: string;
};

const { eyebrow, title, description } = Astro.props;
---

<section class="internal-hero" aria-labelledby="internal-page-title">
  <div class="internal-hero__shell">
    <p class="internal-hero__eyebrow">{eyebrow}</p>
    <div class="internal-hero__content">
      <h1 id="internal-page-title">{title}</h1>
      <p class="internal-hero__description">{description}</p>
    </div>
    <div class="internal-hero__marker" aria-hidden="true">
      <span></span>
      <span></span>
    </div>
  </div>
</section>

<style>
  .internal-hero {
    position: relative;
    min-height: max(38rem, 100svh);
    margin-top: -4.75rem;
    overflow: hidden;
    background:
      linear-gradient(90deg, transparent 0 49.95%, rgba(41, 70, 143, 0.08) 50%, transparent 50.05%),
      var(--color-paper);
    color: var(--color-text-inverse);
  }

  .internal-hero::before {
    position: absolute;
    top: 0;
    right: var(--container-gutter);
    left: var(--container-gutter);
    height: 1px;
    background: rgba(37, 43, 50, 0.14);
    content: "";
  }

  .internal-hero__shell {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    width: min(100%, var(--container-max));
    min-height: inherit;
    margin-inline: auto;
    padding: calc(4.75rem + clamp(3rem, 8vh, 6rem)) var(--container-gutter) clamp(2rem, 5vh, 4rem);
  }

  .internal-hero__eyebrow {
    margin: 0;
    color: var(--color-brand-blue);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(0.68rem, 0.8vw, 0.78rem);
    font-weight: 600;
    letter-spacing: var(--tracking-label);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .internal-hero__content {
    display: grid;
    align-content: center;
    gap: clamp(1.75rem, 4vw, 3.5rem);
    width: min(100%, 72rem);
    min-width: 0;
    padding-block: clamp(4rem, 10vh, 8rem);
  }

  h1 {
    max-width: 13ch;
    min-width: 0;
    margin: 0;
    color: var(--color-brand-graphite);
    font-family: "Space Grotesk", var(--font-display);
    font-size: clamp(3rem, 7.5vw, 7.25rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.96;
    hyphens: auto;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  .internal-hero__description {
    max-width: 42rem;
    margin: 0 0 0 min(15vw, 12rem);
    color: rgba(37, 43, 50, 0.7);
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    line-height: 1.55;
    text-wrap: pretty;
  }

  .internal-hero__marker {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .internal-hero__marker span:first-child {
    width: 2.75rem;
    height: 0.2rem;
    background: var(--color-brand-blue-bright);
  }

  .internal-hero__marker span:last-child {
    width: min(28rem, 44vw);
    height: 1px;
    background: rgba(37, 43, 50, 0.2);
  }

  @media (max-width: 767px) {
    .internal-hero {
      min-height: max(35rem, 100svh);
      margin-top: -4.1rem;
      background: var(--color-paper);
    }

    .internal-hero__shell {
      padding-top: calc(4.1rem + clamp(2.5rem, 7vh, 4rem));
    }

    .internal-hero__content {
      gap: 1.75rem;
      padding-block: 3.5rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.4rem, 11vw, 4.5rem);
      line-height: 1;
    }

    .internal-hero__description {
      max-width: 31rem;
      margin-left: 0;
      font-size: 1rem;
    }

    .internal-hero__marker span:last-child {
      width: 55vw;
    }
  }
</style>
